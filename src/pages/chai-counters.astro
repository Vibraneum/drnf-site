<script>
  // Live Counter Animation
  if (typeof document !== 'undefined') {
    document.addEventListener('DOMContentLoaded', function() {
      const counterElement = document.getElementById('teaCountToday');
      if (counterElement) {
        // Start from a random number close to the base
        const baseCount = 247;
        let currentCount = Math.max(200, baseCount - Math.floor(Math.random() * 50));

        // Animate the counter incrementally
        const animateCounter = () => {
          if (currentCount < baseCount) {
            currentCount += Math.ceil((baseCount - currentCount) / 20);
            if (currentCount > baseCount) currentCount = baseCount;
            counterElement.textContent = currentCount;
          }
        };

        // Initial animation when page loads
        let animationFrames = 0;
        const animationInterval = setInterval(() => {
          animateCounter();
          animationFrames++;
          if (animationFrames > 20) {
            clearInterval(animationInterval);
            startLiveUpdates();
          }
        }, 50);

        // Simulate live updates throughout the day
        const startLiveUpdates = () => {
          setInterval(() => {
            // Simulate 1-3 cups served every 5-15 seconds
            const cupsAdded = Math.floor(Math.random() * 3) + 1;
            currentCount += cupsAdded;
            counterElement.textContent = currentCount;

            // Add a subtle pulse animation
            counterElement.style.transform = 'scale(1.1)';
            setTimeout(() => {
              counterElement.style.transform = 'scale(1)';
            }, 100);
          }, Math.random() * 10000 + 5000);
        };

        // Smooth transition styling
        counterElement.style.transition = 'transform 0.1s ease-out';
      }

      // Current year in footer
      const yearElement = document.getElementById('current-year');
      if (yearElement) {
        yearElement.textContent = new Date().getFullYear();
      }
    });
  }
</script>

