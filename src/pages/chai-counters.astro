---
import Layout from '../layouts/Layout.astro';
import Header from '../components/astro/Header.astro';
import Footer from '../components/astro/Footer.astro';

const pageTitle = 'Free Chai Counters | Dr. Rabinder Nath Foundation';
const pageDescription = 'DRNF operates 2 free chai counters in Hyderabad at KBR Park, LV Prasad, and Basavatarakam junctions, serving 500-600 people daily. Operating 9 AM to 9 PM, 365 days since July 2021.';
---

<Layout title={pageTitle} description={pageDescription}>
  <Header activePage="chai-counters" />
  
<section class="page-hero">
        <div class="container">
            <h1 data-aos="fade-up">Free Chai Counters</h1>
            <p data-aos="fade-up" data-aos-delay="200">"No One Should Sleep Hungry" - Our mission through 365 days of free tea and snacks</p>
        </div>
    </section>

    <!-- Free Chai Counters Section -->
    <section id="chai-counters" class="section">
        <div class="container">
            <!-- Current Status -->
            <div class="current-status" data-aos="fade-up" data-aos-delay="150">
                <div class="status-card">
                    <div class="status-icon">
                        <i class="fas fa-map-marker-alt"></i>
                    </div>
                    <h3>Currently Operating</h3>
                    <p><strong>2 Free Chai Counters</strong> are currently active in Hyderabad, serving the community with free tea, snacks, and support for those in need.</p>
                    <div class="location-details" style="margin-top: 1.5rem;">
                        <p><strong>Locations:</strong> KBR Park, LV Prasad, and Basavatarakam junctions</p>
                        <p><strong>Serving:</strong> 500-600 people daily with free chai and biscuits</p>
                        <p><strong>Operating Hours:</strong> 9 AM to 9 PM, 365 days a year</p>
                        <p><strong>Launch Date:</strong> July 2021</p>
                    </div>
                </div>
            </div>

            <!-- Chai Counter Locations Photos -->
            <div style="margin-top: 4rem;" data-aos="fade-up" data-aos-delay="200">
                <h3 style="text-align: center; margin-bottom: 2.5rem; font-size: 2rem; color: var(--primary-color);">
                    <i class="fas fa-images"></i> Our Chai Counter Locations
                </h3>
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2.5rem;">
                    <figure style="background: white; padding: 1.5rem; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.1);">
                        <img src="images/initiatives/drnf-chai-counter-banjara-hills-active.jpg"
                             alt="DRNF Free Chai Counter at Banjara Hills, Hyderabad - serving homeless community and frontline workers 24/7 with free tea and snacks"
                             loading="lazy"
                             style="width: 100%; height: auto; border-radius: 12px; margin-bottom: 1rem;">
                        <figcaption>
                            <h4 style="color: var(--primary-color); margin-bottom: 0.5rem; font-size: 1.2rem;">
                                <i class="fas fa-map-pin"></i> Banjara Hills Location
                            </h4>
                            <p style="color: var(--text-secondary); font-size: 0.95rem; line-height: 1.6;">
                                Active free chai counter serving the community at KBR Park junction, operating 365 days a year
                            </p>
                        </figcaption>
                    </figure>

                    <figure style="background: white; padding: 1.5rem; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.1);">
                        <img src="images/initiatives/drnf-chai-counter-kadak-house-active.jpg"
                             alt="DRNF Free Chai Counter at Kadak House, Hyderabad - providing free tea service to those in need including cancer patients' families"
                             loading="lazy"
                             style="width: 100%; height: auto; border-radius: 12px; margin-bottom: 1rem;">
                        <figcaption>
                            <h4 style="color: var(--primary-color); margin-bottom: 0.5rem; font-size: 1.2rem;">
                                <i class="fas fa-map-pin"></i> Kadak House Location
                            </h4>
                            <p style="color: var(--text-secondary); font-size: 0.95rem; line-height: 1.6;">
                                Serving near LV Prasad and Basavatarakam hospitals, supporting cancer patients' families and homeless individuals
                            </p>
                        </figcaption>
                    </figure>

                    <figure style="background: white; padding: 1.5rem; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.1);">
                        <img src="images/initiatives/drnf-free-chai-counter.jpg"
                             alt="DRNF free chai counter in action - volunteers serving tea with dignity to homeless and underprivileged community in Hyderabad"
                             loading="lazy"
                             style="width: 100%; height: auto; border-radius: 12px; margin-bottom: 1rem;">
                        <figcaption>
                            <h4 style="color: var(--primary-color); margin-bottom: 0.5rem; font-size: 1.2rem;">
                                <i class="fas fa-heart"></i> Service in Action
                            </h4>
                            <p style="color: var(--text-secondary); font-size: 0.95rem; line-height: 1.6;">
                                Our volunteers serving tea with compassion and dignity - 500-600 people served daily
                            </p>
                        </figcaption>
                    </figure>
                </div>
            </div>

            <!-- LooCafe Partnership -->
            <div class="loocafe-partnership" data-aos="fade-up" data-aos-delay="200">
                <h3><i class="fas fa-handshake"></i> Partnership with LooCafe</h3>
                <div class="partnership-content">
                    <div class="partnership-text">
                        <p>Our free chai counters are strategically implemented through our partnership with <a href="https://loocafe.com" target="_blank" rel="noopener" class="loocafe-link">LooCafe.com</a>, leveraging their extensive network of 270+ locations across Hyderabad.</p>

                        <p>The mission is beautifully documented in <a href="https://loocafe.com/toilettales" target="_blank" rel="noopener" class="loocafe-link">LooCafe's Toilet Tales</a>, showcasing how community-driven initiatives like ours create meaningful impact through innovative partnerships.</p>

                        <div class="partnership-highlights">
                            <div class="highlight-item">
                                <i class="fas fa-network-wired"></i>
                                <span>Integrated with LooCafe's 270+ network</span>
                            </div>
                            <div class="highlight-item">
                                <i class="fas fa-clock"></i>
                                <span>24/7 accessibility through strategic locations</span>
                            </div>
                            <div class="highlight-item">
                                <i class="fas fa-users"></i>
                                <span>Community-centered approach</span>
                            </div>
                        </div>
                    </div>

                    <div class="partnership-visual">
                        <img src="https://res.cloudinary.com/dhupieu4x/image/upload/v1762599305/drnf-assets/drnf-assets/loocafe_no_bg_collage.png" alt="LooCafe Network Partnership">
                        <p class="image-caption">Our partnership with LooCafe enables wider community reach</p>
                    </div>
                </div>
            </div>

            <!-- The LooCafe Model & Social Impact -->
            <div class="loocafe-model-section" data-aos="fade-up" data-aos-delay="250" style="margin-top: 4rem; padding: 3rem; background: linear-gradient(135deg, rgba(102,126,234,0.08) 0%, rgba(118,75,162,0.08) 100%); border-radius: var(--border-radius); border-left: 5px solid var(--primary-color);">
                <h3 style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1.5rem;">
                    <i class="fas fa-lightbulb" style="color: var(--accent-color);"></i>
                    The LooCafe Social Impact Model
                </h3>
                <p style="font-size: 1.1rem; line-height: 1.8; margin-bottom: 2rem; color: var(--text-secondary);">
                    LooCafe is more than just a network of public facilities - it's a revolutionary social impact model backed by the Gates Foundation that has created 1,000+ jobs, empowered street vendors to become entrepreneurs, and provides sustainable infrastructure for community services like our free chai counters.
                </p>

                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem; margin-bottom: 2rem;">
                    <div style="text-align: center; padding: 1.5rem; background: white; border-radius: 12px;">
                        <div style="font-size: 2.5rem; font-weight: 700; color: var(--primary-color);">400+</div>
                        <p style="color: var(--text-secondary); margin: 0;">LooCafe Facilities Across India</p>
                    </div>
                    <div style="text-align: center; padding: 1.5rem; background: white; border-radius: 12px;">
                        <div style="font-size: 2.5rem; font-weight: 700; color: var(--secondary-color);">1000+</div>
                        <p style="color: var(--text-secondary); margin: 0;">Jobs Created</p>
                    </div>
                    <div style="text-align: center; padding: 1.5rem; background: white; border-radius: 12px;">
                        <div style="font-size: 2.5rem; font-weight: 700; color: var(--accent-color);">₹18Cr+</div>
                        <p style="color: var(--text-secondary); margin: 0;">Revenue Generated</p>
                    </div>
                    <div style="text-align: center; padding: 1.5rem; background: white; border-radius: 12px;">
                        <div style="font-size: 2.5rem; font-weight: 700; color: #667eea;">24/7</div>
                        <p style="color: var(--text-secondary); margin: 0;">Accessibility</p>
                    </div>
                </div>

                <div style="text-align: center;">
                    <a href="/loocafe-impact" class="btn btn-primary" style="padding: 1rem 2.5rem; font-size: 1.1rem;">
                        <i class="fas fa-arrow-right" style="margin-right: 0.5rem;"></i>
                        Explore the LooCafe Model
                    </a>
                    <p style="margin-top: 1rem; color: var(--text-secondary); font-size: 0.95rem;">
                        Learn how sustainable infrastructure enables community service
                    </p>
                </div>
            </div>

            <!-- Media Coverage -->
            <div class="media-coverage" data-aos="fade-up" data-aos-delay="200" style="margin-top: 4rem;">
                <h3>Media Coverage</h3>
                <p>Our Supervisors & Service Staff gave media interviews when our free chai counters launched!</p>
                <div class="media-grid">
                    <div class="media-item">
                        <iframe src="https://www.youtube.com/embed/BxVoibxggOI" allowfullscreen></iframe>
                        <p>Telugu Coverage</p>
                    </div>
                    <div class="media-item">
                        <iframe src="https://www.youtube.com/embed/nEcoupO3KD0" allowfullscreen></iframe>
                        <p>Hindi Coverage</p>
                    </div>
                    <div class="media-item">
                        <iframe src="https://www.youtube.com/embed/-Q1ocYVdYCE" allowfullscreen></iframe>
                        <p>Local News</p>
                    </div>
                    <div class="media-item">
                        <iframe src="https://www.youtube.com/embed/7TytQMXMgX8" allowfullscreen></iframe>
                        <p>English by Hybiz TV</p>
                    </div>
                </div>
            </div>

            <!-- News Coverage -->
            <div class="news-coverage" data-aos="fade-up" data-aos-delay="300">
                <a href="https://telanganatoday.com/charitable-trust-launches-free-chai-counter-in-hyderabad" target="_blank" class="news-card">
                    <div class="news-image">
                        <img src="https://res.cloudinary.com/dhupieu4x/image/upload/v1762599293/drnf-assets/drnf-assets/Untitled_2.jpg" alt="Free Chai Counter News">
                    </div>
                    <div class="news-content">
                        <h4>Telangana Today Coverage</h4>
                        <p>Charitable trust launches 'Free Chai Counter' in Hyderabad</p>
                        <span class="read-more">Read Full Article →</span>
                    </div>
                </a>
            </div>

            <!-- Project Highlights -->
            <div class="project-highlights" data-aos="fade-up" data-aos-delay="400">
                <h3><i class="fas fa-coffee"></i> Project Highlights</h3>
                <div class="highlights-grid">
                    <div class="highlight-card">
                        <div class="highlight-icon">
                            <i class="fas fa-clock"></i>
                        </div>
                        <h4>24/7 Service</h4>
                        <p>Open throughout the day, 365 days a year</p>
                    </div>
                    <div class="highlight-card">
                        <div class="highlight-icon">
                            <i class="fas fa-heart"></i>
                        </div>
                        <h4>Community Support</h4>
                        <p>Free Chai and snacks for passersby and homeless community, plus support for cancer patients' families</p>
                    </div>
                    <div class="highlight-card">
                        <div class="highlight-icon">
                            <i class="fas fa-chart-line"></i>
                        </div>
                        <h4>Impact Numbers</h4>
                        <p>Over 20 cups per hour, 1,16,800+ cups served, 17,520+ snacks distributed</p>
                    </div>
                    <div class="highlight-card">
                        <div class="highlight-icon">
                            <i class="fas fa-handshake"></i>
                        </div>
                        <h4>Sustainable Model</h4>
                        <p>Self-sustained with support from <a href="https://ixoragroup.com" target="_blank" rel="noopener">Ixora Group</a>, <a href="https://loocafe.com" target="_blank" rel="noopener">LooCafe</a>, and Kadak Chai partnership</p>
                    </div>
                </div>
            </div>

            <!-- Location Images -->
            <div class="location-images" data-aos="fade-up" data-aos-delay="500">
                <div class="image-grid">
                    <div class="image-item">
                        <img src="https://res.cloudinary.com/dhupieu4x/image/upload/f_auto,q_auto:good/drnf-assets/drnf-assets/drnf-chai-counter-banjara-hills-active.jpg" alt="Free Chai Counter - Banjara Hills Road Location">
                        <div class="image-overlay">
                            <p>Banjara Hills Road - Active Service</p>
                        </div>
                    </div>
                    <div class="image-item">
                        <img src="https://res.cloudinary.com/dhupieu4x/image/upload/f_auto,q_auto:good/drnf-assets/drnf-assets/drnf-chai-counter-kadak-house-active.jpg" alt="Free Chai Counter - Kadak House Location Serving Community">
                        <div class="image-overlay">
                            <p>Kadak House Location - Community Service</p>
                        </div>
                    </div>
                    <div class="image-item">
                        <img src="https://res.cloudinary.com/dhupieu4x/image/upload/f_auto,q_auto:good/drnf-assets/drnf-assets/free-chai-counter-team.jpg" alt="Free Chai Counter Team with Community">
                        <div class="image-overlay">
                            <p>Our Team Serving the Community</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Expansion Plans -->
            <div class="expansion-plans" data-aos="fade-up" data-aos-delay="600">
                <h3>Expansion Across LooCafe Network</h3>
                <div class="expansion-content">
                    <div class="expansion-text">
                        <p>Harnessing the large network of LooCafes - around 270 in Hyderabad - we plan to expand our Free Chai Counter program across the city.</p>
                        <div class="expansion-highlights">
                            <div class="expansion-item">
                                <i class="fas fa-map-marked-alt"></i>
                                <span>270 LooCafes across Hyderabad</span>
                            </div>
                            <div class="expansion-item">
                                <i class="fas fa-users"></i>
                                <span>Partnerships with local business owners</span>
                            </div>
                            <div class="expansion-item">
                                <i class="fas fa-calendar-check"></i>
                                <span>Piloted across 30 LooCafes in 2022-2023</span>
                            </div>
                        </div>
                        <p class="update-note">
                            <strong>Update:</strong> We successfully piloted this expansive program across 30 LooCafes in Hyderabad in 2022-2023, and it has worked out wonderfully. Soon we hope to expand and make it a permanent project across India.
                        </p>
                    </div>
                    <div class="expansion-visual">
                        <img src="https://res.cloudinary.com/dhupieu4x/image/upload/v1762599305/drnf-assets/drnf-assets/loocafe_no_bg_collage.png" alt="LooCafe Network">
                        <img src="https://res.cloudinary.com/dhupieu4x/image/upload/v1762599290/drnf-assets/drnf-assets/LooCafe_Workstation.jpg" alt="LooCafe Workstation">
                    </div>
                </div>
            </div>

            <!-- Employment Section -->
            <div class="employment-section" data-aos="fade-up" data-aos-delay="700">
                <h3>Creating Employment</h3>
                <div class="employment-stats">
                    <div class="employment-card">
                        <div class="employment-number">40+</div>
                        <div class="employment-label">Full-time Associates</div>
                        <p>Working with donation drives, free sanitation centers, free chai counters and more</p>
                    </div>
                    <div class="employment-card">
                        <div class="employment-number">70+</div>
                        <div class="employment-label">Jobs Created Previously</div>
                        <p>We're committed to continuously creating meaningful employment opportunities</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Social Share Section -->
    <section class="section">
        <div class="container">
            <div class="social-share-section" data-aos="fade-up">
                <h3>Share Our Mission</h3>
                <p>Help us spread the word about our impact and free chai initiative</p>
                <div class="share-buttons">
                    <a href="https://www.facebook.com/sharer/sharer.php?u=" class="share-btn facebook" target="_blank" rel="noopener noreferrer" data-share="facebook">
                        <i class="fab fa-facebook-f"></i>
                        <span>Facebook</span>
                    </a>
                    <a href="https://twitter.com/intent/tweet?url=" class="share-btn twitter" target="_blank" rel="noopener noreferrer" data-share="twitter">
                        <i class="fab fa-x-twitter"></i>
                        <span>Twitter</span>
                    </a>
                    <a href="https://www.linkedin.com/sharing/share-offsite/?url=" class="share-btn linkedin" target="_blank" rel="noopener noreferrer" data-share="linkedin">
                        <i class="fab fa-linkedin-in"></i>
                        <span>LinkedIn</span>
                    </a>
                    <a href="https://wa.me/?text=Check%20out%20DRNF's%20Free%20Chai%20Counters%20-%20" class="share-btn whatsapp" target="_blank" rel="noopener noreferrer" data-share="whatsapp">
                        <i class="fab fa-whatsapp"></i>
                        <span>WhatsApp</span>
                    </a>
                </div>
            </div>
        </div>
    </section>

  <!-- Back to Top Button -->
  <button class="back-to-top" id="backToTop" aria-label="Back to top">
    <i class="fas fa-arrow-up"></i>
  </button>

  <Footer />
</Layout>

<script>
  // Current year in footer
  if (typeof document !== 'undefined') {
    const yearElement = document.getElementById('current-year');
    if (yearElement) {
      yearElement.textContent = new Date().getFullYear();
    }
  }
</script>
