---
import Layout from '../layouts/Layout.astro';
import Card from '../components/astro/Card.astro';
import Counter from '../components/react/Counter';
---

<Layout title="Test Page - DRNF" description="Testing React and Astro components">
  <main class="min-h-screen bg-gradient-to-br from-green-50 to-orange-50">
    <div class="container mx-auto px-4 py-16">
      <h1 class="text-4xl font-bold text-green-800 mb-8">Component Test Page</h1>

      <div class="grid gap-6 md:grid-cols-2 mb-8">
        <Card title="Astro Component" description="This is a static Astro component">
          <p class="mt-4 text-sm text-gray-500">Built with Astro - no client-side JavaScript</p>
        </Card>

        <Card title="React Component Below">
          <div class="mt-4">
            <Counter client:load initial={5} />
          </div>
        </Card>
      </div>

      <div class="bg-white rounded-lg shadow-md p-6">
        <h2 class="text-2xl font-semibold text-orange-600 mb-4">Technology Stack</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div class="text-center p-4 bg-blue-50 rounded">
            <div class="text-3xl mb-2">🚀</div>
            <div class="font-semibold">Astro</div>
            <div class="text-sm text-gray-600">v5.15.5</div>
          </div>
          <div class="text-center p-4 bg-cyan-50 rounded">
            <div class="text-3xl mb-2">⚛️</div>
            <div class="font-semibold">React</div>
            <div class="text-sm text-gray-600">v19.2.0</div>
          </div>
          <div class="text-center p-4 bg-sky-50 rounded">
            <div class="text-3xl mb-2">🎨</div>
            <div class="font-semibold">Tailwind</div>
            <div class="text-sm text-gray-600">v4.1.17</div>
          </div>
          <div class="text-center p-4 bg-indigo-50 rounded">
            <div class="text-3xl mb-2">📘</div>
            <div class="font-semibold">TypeScript</div>
            <div class="text-sm text-gray-600">Strict</div>
          </div>
        </div>
      </div>

      <div class="mt-8 text-center">
        <a
          href="/"
          class="inline-block px-6 py-3 bg-green-600 text-white rounded-lg hover:bg-green-700 transition"
        >
          Back to Home
        </a>
      </div>
    </div>
  </main>
</Layout>
