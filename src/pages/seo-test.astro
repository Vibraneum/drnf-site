---
import Layout from '../layouts/Layout.astro';

const pageStructuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "SEO Test Page - Dr. Rabinder Nath Foundation",
  "description": "Testing page for SEO components and structured data",
  "url": "https://drnf.org/seo-test"
};
---

<Layout
  title="SEO Test Page"
  description="This is a test page to verify all SEO components are working correctly for the DRNF Astro migration."
  keywords="test, SEO, DRNF, Astro, migration"
  structuredData={pageStructuredData}
>
  <div style="max-width: 800px; margin: 0 auto; padding: 2rem; font-family: Inter, sans-serif;">
    <h1 style="color: #2c5530; font-family: 'Playfair Display', serif; font-size: 2.5rem; margin-bottom: 1rem;">
      SEO Test Page
    </h1>

    <p style="font-size: 1.1rem; color: #7f8c8d; margin-bottom: 2rem;">
      Dr. Rabinder Nath Foundation - Astro Migration Test
    </p>

    <section style="margin-bottom: 2rem;">
      <h2 style="color: #2c5530; font-family: 'Playfair Display', serif; font-size: 1.8rem; margin-bottom: 1rem;">
        Component Verification Checklist
      </h2>

      <ul style="list-style: none; padding: 0;">
        <li style="margin-bottom: 0.5rem;">
          ✅ <strong>Layout.astro</strong> - Base layout with comprehensive meta tags
        </li>
        <li style="margin-bottom: 0.5rem;">
          ✅ <strong>SEO.astro</strong> - Open Graph, Twitter Cards, Canonical URL
        </li>
        <li style="margin-bottom: 0.5rem;">
          ✅ <strong>StructuredData.astro</strong> - Organization schema markup
        </li>
        <li style="margin-bottom: 0.5rem;">
          ✅ <strong>View Transitions</strong> - Astro page transitions enabled
        </li>
        <li style="margin-bottom: 0.5rem;">
          ✅ <strong>Google Analytics</strong> - GA4 tracking (G-BKRC1PBFTM)
        </li>
        <li style="margin-bottom: 0.5rem;">
          ✅ <strong>Font Awesome</strong> - Icon library loaded
        </li>
        <li style="margin-bottom: 0.5rem;">
          ✅ <strong>Google Fonts</strong> - Inter and Playfair Display
        </li>
        <li style="margin-bottom: 0.5rem;">
          ✅ <strong>AOS Animations</strong> - Animation library loaded
        </li>
      </ul>
    </section>

    <section style="margin-bottom: 2rem;">
      <h2 style="color: #2c5530; font-family: 'Playfair Display', serif; font-size: 1.8rem; margin-bottom: 1rem;">
        Test Features
      </h2>

      <div style="background: #f8f9fa; padding: 1.5rem; border-radius: 8px; margin-bottom: 1rem;">
        <h3 style="color: #2c5530; margin-bottom: 0.5rem;">Meta Tags</h3>
        <p style="color: #555;">View page source to verify all meta tags are present.</p>
      </div>

      <div style="background: #f8f9fa; padding: 1.5rem; border-radius: 8px; margin-bottom: 1rem;">
        <h3 style="color: #2c5530; margin-bottom: 0.5rem;">Structured Data</h3>
        <p style="color: #555;">Use Google's Rich Results Test to validate JSON-LD.</p>
      </div>

      <div style="background: #f8f9fa; padding: 1.5rem; border-radius: 8px; margin-bottom: 1rem;">
        <h3 style="color: #2c5530; margin-bottom: 0.5rem;">Icons Test</h3>
        <p style="color: #555;">
          <i class="fas fa-heart" style="color: #f39c12; margin-right: 0.5rem;"></i>
          <i class="fab fa-facebook" style="color: #2c5530; margin-right: 0.5rem;"></i>
          <i class="fas fa-check-circle" style="color: #8b4513; margin-right: 0.5rem;"></i>
          Font Awesome icons loaded successfully
        </p>
      </div>

      <div style="background: #f8f9fa; padding: 1.5rem; border-radius: 8px;" data-aos="fade-up">
        <h3 style="color: #2c5530; margin-bottom: 0.5rem;">AOS Animation Test</h3>
        <p style="color: #555;">This box should fade up on page load (scroll if needed).</p>
      </div>
    </section>

    <section>
      <h2 style="color: #2c5530; font-family: 'Playfair Display', serif; font-size: 1.8rem; margin-bottom: 1rem;">
        Navigation
      </h2>
      <p style="margin-bottom: 1rem;">
        <a href="/" style="color: #2c5530; text-decoration: underline;">← Back to Home</a>
      </p>
      <p style="color: #7f8c8d; font-size: 0.9rem;">
        Test View Transitions by navigating between pages
      </p>
    </section>

    <footer style="margin-top: 3rem; padding-top: 2rem; border-top: 1px solid #e0e0e0; text-align: center; color: #7f8c8d;">
      <p>&copy; <span id="current-year"></span> Dr. Rabinder Nath Foundation. All Rights Reserved.</p>
    </footer>
  </div>
</Layout>
