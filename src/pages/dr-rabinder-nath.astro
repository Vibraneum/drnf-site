---
import Layout from '../layouts/Layout.astro';

const pageTitle = 'Dr. Rabinder Nath - Dental Surgeon, Philanthropist, Pioneer | DRNF';
const pageDescription = 'Comprehensive biography of Dr. Rabinder Nath (1951-present) - pioneering dental surgeon, rural healthcare innovator, and philanthropist.';
---

<Layout title={pageTitle} description={pageDescription} activePage="dr-rabinder-nath">
  
<section class="page-header">
        <div class="container">
            <h1 data-aos="fade-up">Dr. Rabinder Nath</h1>
            <p class="subtitle" data-aos="fade-up" data-aos-delay="100">
                Dental Surgeon, Rural Healthcare Pioneer, Philanthropist<br>
                Third Generation of Medical Excellence Serving Hyderabad Since 1956
            </p>

            <div class="vital-stats" data-aos="fade-up" data-aos-delay="200">
                <div class="vital-stat">
                    <span class="number">80,000+</span>
                    <span class="label">Patients Treated Free</span>
                </div>
                <div class="vital-stat">
                    <span class="number">3</span>
                    <span class="label">Generations of Doctors</span>
                </div>
                <div class="vital-stat">
                    <span class="number">68+</span>
                    <span class="label">Years of Service</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Main Content -->
    <section class="section">
        <div class="container" style="max-width: 1400px;">
            <div style="display: grid; grid-template-columns: 300px 1fr; gap: 3rem; align-items: start;">

                <!-- Table of Contents -->
                <aside class="page-toc" data-aos="fade-right">
                    <h3><i class="fas fa-list"></i> Contents</h3>
                    <nav>
                        <a href="#early-life" class="toc-link">Early Life & Education</a>
                        <a href="#medical-career" class="toc-link">Medical Career</a>
                        <a href="#research" class="toc-link">Research & Innovation</a>
                        <a href="#rural-healthcare" class="toc-link">Rural Healthcare Legacy</a>
                        <a href="#awards" class="toc-link">Awards & Recognition</a>
                        <a href="#family-lineage" class="toc-link">Family & Lineage</a>
                        <a href="#clinic-today" class="toc-link">The Clinic Today</a>
                        <a href="#sources" class="toc-link">Sources & References</a>
                    </nav>
                </aside>

                <!-- Main Content -->
                <main>
                    <!-- Early Life & Education -->
                    <article id="early-life" class="content-section" data-aos="fade-up">
                        <h2><i class="fas fa-graduation-cap"></i> Early Life & Education</h2>

                        <p style="font-size: 1.2rem; line-height: 1.8; margin-bottom: 2rem;">
                            Born on <strong>February 15, 1951</strong> in Hyderabad, Dr. Rabinder Nath was the son of Dr. Upendra Nath, personal dental physician to the Nizam of Hyderabad, and grandson of Dr. Prem Nath, India's first qualified dental surgeon. Despite this prestigious lineage, the family had lost much through the upheavals of partition, and Dr. Rabinder Nath's achievements were built through <strong>education, determination, and merit</strong>.
                        </p>

                        <div class="bio-grid">
                            <div class="bio-card" data-aos="fade-up">
                                <h4><i class="fas fa-school icon"></i> School Education</h4>
                                <p><strong>Little Flower High School</strong><br>Hyderabad, Telangana</p>
                                <p style="margin-top: 1rem; font-size: 0.95rem; color: var(--text-secondary);">
                                    Foundation years that shaped his commitment to service and excellence
                                </p>
                            </div>

                            <div class="bio-card" data-aos="fade-up" data-aos-delay="100">
                                <h4><i class="fas fa-flask icon"></i> Undergraduate</h4>
                                <p><strong>B.Sc. - Andhra Vidyalaya College (A.V. College)</strong></p>
                                <p style="margin-top: 1rem;">
                                    <strong>First Union President</strong> - Demonstrated early leadership in student politics and representation
                                </p>
                            </div>

                            <div class="bio-card" data-aos="fade-up" data-aos-delay="200">
                                <h4><i class="fas fa-tooth icon"></i> Dental Education</h4>
                                <p><strong>B.D.S. - Osmania Medical College</strong><br>Hyderabad</p>
                                <p style="margin-top: 1rem;">
                                    <strong>Chairman, Dental Students Federation of India</strong> - National student leadership position showcasing organizational ability
                                </p>
                            </div>

                            <div class="bio-card" data-aos="fade-up" data-aos-delay="300">
                                <h4><i class="fas fa-user-md icon"></i> Advanced Training</h4>
                                <p><strong>Lucknow Dental College (1974)</strong><br>Specialization in Oral Surgery</p>
                                <p style="margin-top: 1rem; font-size: 0.95rem; color: var(--text-secondary);">
                                    Advanced surgical techniques for complex dental procedures
                                </p>
                            </div>

                            <div class="bio-card" data-aos="fade-up" data-aos-delay="400">
                                <h4><i class="fas fa-certificate icon"></i> International Qualification</h4>
                                <p><strong>M.R.S.H. (Member of the Royal Society of Health)</strong><br>Royal College of Surgeons, England</p>
                                <p style="margin-top: 1rem; font-size: 0.95rem; color: var(--text-secondary);">
                                    Prestigious international recognition of expertise in public health and surgery
                                </p>
                            </div>
                        </div>
                    </article>

                    <!-- Medical Career -->
                    <article id="medical-career" class="content-section" data-aos="fade-up">
                        <h2><i class="fas fa-hospital"></i> Medical Career & Dental Practice</h2>

                        <p style="font-size: 1.2rem; line-height: 1.8; margin-bottom: 2rem;">
                            Dr. Rabinder Nath joined the family practice at <strong>Nath Dental & Oral Surgery Clinic</strong> (founded 1956 by his father Dr. Upendra Nath) and expanded it into a renowned center for dental care in Hyderabad. His practice philosophy combined clinical excellence with compassionate care, treating patients from all walks of life.
                        </p>

                        <div class="bio-grid">
                            <div class="bio-card" data-aos="fade-up">
                                <h4><i class="fas fa-map-marker-alt icon"></i> Primary Practice</h4>
                                <p><strong>Nath Dental & Oral Surgery Clinic</strong></p>
                                <p>3-5-809, Nath Nivas<br>King Koti Road, Hyderguda<br>Hyderabad - 500029</p>
                                <p style="margin-top: 1rem; font-size: 0.9rem;">
                                    <i class="fas fa-clock"></i> Mon-Sun: 10:00 AM - 2:00 PM, 5:30 PM - 9:00 PM
                                </p>
                            </div>

                            <div class="bio-card" data-aos="fade-up" data-aos-delay="100">
                                <h4><i class="fas fa-stethoscope icon"></i> Specializations</h4>
                                <ul>
                                    <li>Oral & Maxillofacial Surgery</li>
                                    <li>Advanced Dental Treatments</li>
                                    <li>Dental Implants</li>
                                    <li>Complex Extractions</li>
                                    <li>Dental Restoration</li>
                                    <li>Preventive Dentistry</li>
                                </ul>
                            </div>

                            <div class="bio-card" data-aos="fade-up" data-aos-delay="200">
                                <h4><i class="fas fa-users icon"></i> Patient Base</h4>
                                <p>Served diverse patient community including:</p>
                                <ul>
                                    <li>Government officials & dignitaries</li>
                                    <li>Corporate professionals</li>
                                    <li>Students & families</li>
                                    <li>Rural patients (through mobile unit)</li>
                                    <li>Underprivileged communities (free treatment)</li>
                                </ul>
                            </div>
                        </div>

                        <div class="highlight-section" data-aos="fade-up" style="margin-top: 3rem;">
                            <h3><i class="fas fa-quote-left"></i> Practice Philosophy</h3>
                            <p style="font-size: 1.15rem; line-height: 1.9; font-style: italic;">
                                "Healthcare is not a privilege of the wealthy—it is a fundamental right. Every patient, whether they can afford treatment or not, deserves the same standard of care, the same dignity, and the same compassion."
                            </p>
                        </div>
                    </article>

                    <!-- Research & Innovation -->
                    <article id="research" class="content-section" data-aos="fade-up">
                        <h2><i class="fas fa-microscope"></i> Research & Innovation</h2>

                        <div class="bio-grid">
                            <div class="bio-card" data-aos="fade-up">
                                <h4><i class="fas fa-pills icon"></i> Pharmaceutical Research</h4>
                                <h5 style="color: var(--accent-color); margin: 1rem 0;">Mefenamic Acid Field Trials</h5>
                                <p>
                                    Conducted pioneering clinical field trials on <strong>Mefenamic acid</strong>, a non-steroidal anti-inflammatory drug (NSAID) used for pain relief and inflammation management.
                                </p>
                                <p style="margin-top: 1rem;">
                                    Following successful trials, R.R. Labs Hyderabad developed and commercialized <strong>"Tromaril"</strong>, bringing affordable pain management to millions of patients across India.
                                </p>
                                <p style="margin-top: 1rem; font-size: 0.95rem; color: var(--text-secondary);">
                                    <i class="fas fa-lightbulb"></i> This research contributed to making effective pain relief accessible to the masses at affordable prices.
                                </p>
                            </div>

                            <div class="bio-card" data-aos="fade-up" data-aos-delay="100">
                                <h4><i class="fas fa-ambulance icon"></i> Mobile Healthcare Innovation</h4>
                                <h5 style="color: var(--accent-color); margin: 1rem 0;">Portadent Mobile Dental Unit</h5>
                                <p>
                                    Established <strong>"Portadent"</strong>, a pioneering mobile dental unit designed to bring advanced dental care directly to rural and underserved populations.
                                </p>
                                <p style="margin-top: 1rem;">
                                    The mobile unit was equipped with:
                                </p>
                                <ul style="margin-top: 0.5rem;">
                                    <li>Portable dental chairs</li>
                                    <li>Sterilization equipment</li>
                                    <li>Basic surgical instruments</li>
                                    <li>Emergency dental supplies</li>
                                    <li>Educational materials</li>
                                </ul>
                                <p style="margin-top: 1rem; font-size: 0.95rem; color: var(--text-secondary);">
                                    <i class="fas fa-heart"></i> Reached villages and communities that had never seen a dentist before.
                                </p>
                            </div>
                        </div>
                    </article>

                    <!-- Rural Healthcare Legacy -->
                    <article id="rural-healthcare" class="content-section" data-aos="fade-up">
                        <h2><i class="fas fa-hands-helping"></i> Rural Healthcare Legacy</h2>

                        <p style="font-size: 1.2rem; line-height: 1.8; margin-bottom: 3rem;">
                            Dr. Rabinder Nath's most enduring contribution was establishing healthcare infrastructure in rural areas where none existed. His commitment to serving the poor and underprivileged went beyond urban practice to create lasting institutions in underserved regions.
                        </p>

                        <div class="generation-item" data-aos="fade-up">
                            <h4><i class="fas fa-hospital-alt"></i> Rani Nath Memorial Hospital</h4>
                            <div class="years">Founded 1992</div>
                            <div class="title">Named in honor of his late mother, Rani Nath</div>

                            <div style="background: var(--background-light); padding: 2rem; border-radius: 12px; margin-top: 1.5rem;">
                                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 2rem;">
                                    <div>
                                        <div style="font-size: 2.5rem; font-weight: 700; color: var(--accent-color);">80,000+</div>
                                        <div style="font-size: 1.1rem; color: var(--text-secondary);">Patients Treated</div>
                                    </div>
                                    <div>
                                        <div style="font-size: 2.5rem; font-weight: 700; color: var(--accent-color);">100%</div>
                                        <div style="font-size: 1.1rem; color: var(--text-secondary);">Free Treatment</div>
                                    </div>
                                    <div>
                                        <div style="font-size: 2.5rem; font-weight: 700; color: var(--accent-color);">Free</div>
                                        <div style="font-size: 1.1rem; color: var(--text-secondary);">Medicines Provided</div>
                                    </div>
                                </div>
                            </div>

                            <p style="margin-top: 2rem; font-size: 1.1rem; line-height: 1.8;">
                                <strong>Location:</strong> Shamirpet, Ranga Reddy District, Telangana
                            </p>

                            <p style="margin-top: 1.5rem; line-height: 1.8;">
                                The hospital served as a comprehensive healthcare facility providing:
                            </p>
                            <ul style="margin-top: 1rem; line-height: 1.8;">
                                <li>Primary healthcare consultations</li>
                                <li>Dental treatments and oral surgery</li>
                                <li>Medical education and awareness programs</li>
                                <li>Mass immunization campaigns across rural areas</li>
                                <li>Preventive health screenings</li>
                                <li>Emergency medical services</li>
                            </ul>

                            <div style="background: linear-gradient(135deg, #f0fff4 0%, #ffffff 100%); padding: 1.5rem; border-radius: 8px; margin-top: 2rem; border-left: 4px solid var(--accent-color);">
                                <p style="font-size: 1.05rem; line-height: 1.8; margin: 0;">
                                    <i class="fas fa-star" style="color: var(--accent-color); margin-right: 0.5rem;"></i>
                                    <strong>Impact:</strong> For many patients, this was their first access to professional medical care. The hospital operated on a model where no patient was ever turned away due to inability to pay.
                                </p>
                            </div>
                        </div>

                        <div class="generation-item" data-aos="fade-up" data-aos-delay="100">
                            <h4><i class="fas fa-hospital"></i> Mahabubnagar Rural Dental Hospital</h4>
                            <div class="title">Serving one of Telangana's most backward districts</div>

                            <p style="margin-top: 1.5rem; line-height: 1.8;">
                                Established a dedicated rural dental hospital in <strong>Mahabubnagar district</strong>, one of the most economically disadvantaged regions of Telangana at the time. The hospital focused specifically on oral health, which was critically neglected in rural areas.
                            </p>

                            <p style="margin-top: 1.5rem; line-height: 1.8;">
                                <strong>Services Provided:</strong>
                            </p>
                            <ul style="margin-top: 1rem; line-height: 1.8;">
                                <li>Free dental consultations and examinations</li>
                                <li>Tooth extractions and emergency dental care</li>
                                <li>Preventive oral health education</li>
                                <li>School dental health programs</li>
                                <li>Community awareness campaigns</li>
                            </ul>

                            <div style="background: linear-gradient(135deg, #fff5f5 0%, #ffffff 100%); padding: 1.5rem; border-radius: 8px; margin-top: 2rem; border-left: 4px solid var(--secondary-color);">
                                <p style="font-size: 1.05rem; line-height: 1.8; margin: 0;">
                                    <i class="fas fa-heartbeat" style="color: var(--secondary-color); margin-right: 0.5rem;"></i>
                                    Many rural communities in Mahabubnagar had never seen a dentist before this hospital opened. It addressed critical oral health issues that often went untreated, causing severe pain and health complications.
                                </p>
                            </div>

                            <!-- Memorial Dental Camp Image -->
                            <div style="margin-top: 2rem; text-align: center;" data-aos="fade-up">
                                <img src="https://res.cloudinary.com/dhupieu4x/image/upload/f_auto,q_auto:good/drnf-assets/drnf-assets/dr-rabinder-nath-memorial-dental-camp.jpg" alt="Free Dental Check-up Camp in Memory of Dr. Rabinder Nath" style="max-width: 100%; height: auto; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
                                <p style="margin-top: 1rem; font-style: italic; color: var(--text-secondary); font-size: 0.95rem;">
                                    Free Dental Check-up Camp organized in fond memory of Late Dr. Rabinder Nath by Nath Dental & Oral Surgery Clinic, continuing his legacy of compassionate community healthcare.
                                </p>
                            </div>
                        </div>
                    </article>

                    <!-- Awards & Recognition -->
                    <article id="awards" class="content-section" data-aos="fade-up">
                        <h2><i class="fas fa-award"></i> Awards & Recognition</h2>

                        <div class="bio-grid">
                            <div class="bio-card" data-aos="fade-up" style="border-top-color: #d4af37;">
                                <h4><i class="fas fa-trophy icon"></i> Vijayshree Award</h4>
                                <p style="font-size: 1.1rem; font-weight: 600; color: var(--primary-color); margin-bottom: 1rem;">
                                    For Outstanding Services to Rural Healthcare
                                </p>
                                <p style="line-height: 1.8;">
                                    Recognized for pioneering work in establishing healthcare infrastructure in rural and underserved areas of Telangana. The award honored his commitment to providing free medical treatment to thousands of patients who could not afford care.
                                </p>
                            </div>

                            <div class="bio-card" data-aos="fade-up" data-aos-delay="100" style="border-top-color: #d4af37;">
                                <h4><i class="fas fa-globe-americas icon"></i> Glory of India International Award</h4>
                                <p style="font-size: 1.1rem; font-weight: 600; color: var(--primary-color); margin-bottom: 1rem;">
                                    Recommended by American & Canadian Medical Delegation
                                </p>
                                <p style="line-height: 1.8;">
                                    A team of doctors from America and Canada visited Dr. Rabinder Nath's rural hospitals and were "immensely satisfied with his work." They recommended him for this prestigious international recognition honoring his contributions to healthcare accessibility and social welfare.
                                </p>
                                <div style="background: var(--background-light); padding: 1rem; border-radius: 8px; margin-top: 1rem; font-size: 0.95rem;">
                                    <i class="fas fa-quote-left" style="color: var(--accent-color);"></i>
                                    <em>"His model of combining quality medical care with social service demonstrates what healthcare should be worldwide."</em>
                                </div>
                            </div>
                        </div>
                    </article>

                    <!-- Family & Lineage -->
                    <article id="family-lineage" class="content-section" data-aos="fade-up">
                        <h2><i class="fas fa-users"></i> Family & Three Generations of Medical Service</h2>

                        <p style="font-size: 1.2rem; line-height: 1.8; margin-bottom: 3rem;">
                            The Nath family represents three generations of pioneering medical service to India, each building upon the foundation laid by the previous generation while forging their own path of innovation and service.
                        </p>

                        <div class="generation-timeline">
                            <!-- Generation 1 -->
                            <div class="generation-item" data-aos="fade-up">
                                <h4>Dr. Prem Nath</h4>
                                <div class="years">First Generation</div>
                                <div class="title">India's First Qualified Dental Surgeon</div>
                                <p style="margin-top: 1.5rem; line-height: 1.8;">
                                    Dr. Prem Nath holds the distinction of being recognized as <strong>India's first qualified dental surgeon</strong>, pioneering the profession of dentistry in the country during the early 20th century. His groundbreaking work established dentistry as a respected medical field in India and paved the way for modern dental education and practice.
                                </p>
                            </div>

                            <!-- Generation 2 -->
                            <div class="generation-item" data-aos="fade-up" data-aos-delay="100">
                                <h4>Dr. Upendra Nath (Dr. Upender Nath)</h4>
                                <div class="years">Second Generation • Founded Nath Dental Clinic (1956)</div>
                                <div class="title">Personal Dental Physician to the Nizam of Hyderabad</div>
                                <p style="margin-top: 1.5rem; line-height: 1.8;">
                                    Following in his father's footsteps, Dr. Upendra Nath became a <strong>renowned oral surgeon</strong> and served as the personal dental physician to <strong>the Nizam of Hyderabad</strong> and subsequent state governors. In 1956, he founded <strong>Nath Dental & Oral Surgery Clinic</strong> at Nath Nivas, Hyderguda, establishing what would become a family legacy of medical service spanning nearly 70 years.
                                </p>
                                <div style="background: var(--background-light); padding: 1.5rem; border-radius: 8px; margin-top: 1.5rem;">
                                    <p style="margin: 0; line-height: 1.8;">
                                        <i class="fas fa-star" style="color: var(--accent-color);"></i>
                                        <strong>Legacy:</strong> "His work and fame is still remembered by his patients and friends" who continue to speak of his skill and dedication decades later.
                                    </p>
                                </div>
                            </div>

                            <!-- Generation 3 -->
                            <div class="generation-item" data-aos="fade-up" data-aos-delay="200" style="border-left-color: var(--accent-color);">
                                <h4>Dr. Rabinder Nath</h4>
                                <div class="years">Third Generation • Born February 15, 1951</div>
                                <div class="title">Pioneering Rural Healthcare & Philanthropy</div>
                                <p style="margin-top: 1.5rem; line-height: 1.8;">
                                    Dr. Rabinder Nath expanded the family legacy beyond urban practice to serve rural and underprivileged populations. He established Rani Nath Memorial Hospital (serving 80,000+ patients with free treatment), pioneered mobile dental healthcare through Portadent, conducted pharmaceutical research, and earned international recognition for his social service work.
                                </p>
                            </div>
                        </div>

                        <h3 style="margin-top: 4rem;"><i class="fas fa-heart"></i> Personal Life</h3>
                        <div class="bio-card" data-aos="fade-up">
                            <p style="font-size: 1.1rem; line-height: 1.8;">
                                Dr. Rabinder Nath was married to <strong>Mrs. Neelam Nath</strong>. Together they had two children who continue the family's tradition of service and innovation.
                            </p>
                            <p style="margin-top: 1.5rem; line-height: 1.8;">
                                <strong>Son:</strong> Abhishek Nath - Founder of <a href="https://loocafe.com" target="_blank" rel="noopener">LooCafe</a> (WASH organization) and <strong>Dr. Rabinder Nath Foundation</strong> (established 2016), carrying forward the family's commitment to social service through innovative community programs including free chai counters and sanitation initiatives.
                            </p>
                        </div>
                    </article>

                    <!-- The Clinic Today -->
                    <article id="clinic-today" class="content-section" data-aos="fade-up">
                        <h2><i class="fas fa-clinic-medical"></i> Nath Dental & Oral Surgery Clinic Today</h2>

                        <p style="font-size: 1.2rem; line-height: 1.8; margin-bottom: 3rem;">
                            Now in its <strong>68th year of operation</strong> (1956-2024), Nath Dental & Oral Surgery Clinic continues to serve the community with the same commitment to excellence and compassion that Dr. Upendra Nath established and Dr. Rabinder Nath expanded.
                        </p>

                        <div class="highlight-section" data-aos="fade-up" style="margin-bottom: 3rem;">
                            <h3><i class="fas fa-map-marker-alt"></i> Location & Hours</h3>
                            <p style="font-size: 1.15rem; margin-bottom: 1rem;">
                                <strong>Nath Dental & Oral Surgery Clinic</strong><br>
                                3-5-809, Nath Nivas, King Koti Road, Hyderguda<br>
                                Landmark: Beside Bahar Cafe<br>
                                Hyderabad, Telangana - 500029
                            </p>
                            <p style="font-size: 1.1rem; color: var(--accent-color); font-weight: 600;">
                                <i class="fas fa-clock"></i> Monday - Sunday: 10:00 AM - 2:00 PM & 5:30 PM - 9:00 PM
                            </p>
                        </div>

                        <h3><i class="fas fa-user-md"></i> Current Practitioners</h3>
                        <p style="font-size: 1.1rem; line-height: 1.8; margin-bottom: 2rem;">
                            The clinic continues Dr. Rabinder Nath's legacy through dedicated professionals committed to the same standards of care:
                        </p>

                        <div class="bio-grid">
                            <div class="bio-card" data-aos="fade-up" style="border-top-color: var(--primary-color);">
                                <h4><i class="fas fa-tooth icon"></i> Dr. Niharika Nath</h4>
                                <div style="color: var(--accent-color); font-weight: 600; margin-bottom: 1rem;">
                                    BDS • 26+ Years Experience
                                </div>
                                <p style="line-height: 1.8; margin-bottom: 1rem;">
                                    <strong>Education:</strong> BDS, S.B. Patil Dental College & Hospital, Karnataka (1998)
                                </p>
                                <p style="line-height: 1.8; margin-bottom: 1rem;">
                                    <strong>Professional Registration:</strong>
                                </p>
                                <ul style="font-size: 0.95rem;">
                                    <li>Telangana State Dental Council: #287</li>
                                    <li>Andhra Pradesh State Dental Council: #4942 (2007)</li>
                                    <li>Member, Indian Dental Association</li>
                                </ul>
                                <p style="margin-top: 1rem; line-height: 1.8;">
                                    <strong>Past Experience:</strong> Senior Dental Surgeon at Apollo White Dental
                                </p>
                                <p style="margin-top: 1rem; line-height: 1.8;">
                                    <strong>Specializations:</strong> BPS Dentures, Dental Implants, Laser Dentistry, Cosmetic Dentistry, Dental Restoration
                                </p>
                                <div style="background: var(--background-light); padding: 1rem; border-radius: 8px; margin-top: 1.5rem;">
                                    <p style="margin: 0; font-size: 0.95rem;">
                                        <i class="fas fa-star" style="color: var(--accent-color);"></i>
                                        Continuing Dr. Rabinder Nath's practice with modern techniques and compassionate care
                                    </p>
                                </div>
                            </div>

                            <div class="bio-card" data-aos="fade-up" data-aos-delay="100" style="border-top-color: var(--secondary-color);">
                                <h4><i class="fas fa-user-md icon"></i> Dr. Narendra Nath</h4>
                                <div style="color: var(--accent-color); font-weight: 600; margin-bottom: 1rem;">
                                    MBBS • Anesthesiologist & Physician
