                  </div>
              </li>

              <li><a href="contact.html" class="nav-link-enhanced">Contact</a></li>
              <li><a href="faq.html" class="nav-link-enhanced">FAQ</a></li>
          </ul>

          <!-- Navigation Actions -->
          <div class="nav-actions-enhanced">
              <a href="contact.html" class="nav-cta-enhanced">Contact</a>
              <button class="mobile-menu-toggle" aria-label="Toggle mobile menu">
                  <span></span>
                  <span></span>
                  <span></span>
              </button>
          </div>
      </div>

      <!-- About Mega Menu -->
      <div class="mega-menu" id="about-mega-menu">
          <div class="mega-menu-container">
