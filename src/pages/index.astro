  <!-- Global Styles for Enhancements -->
  <style>
      @keyframes heartbeat {
          0% {
              transform: scale(1);
          }
          25% {
              transform: scale(1.1);
          }
          50% {
              transform: scale(1);
          }
          75% {
              transform: scale(1.1);
          }
          100% {
              transform: scale(1);
          }
      }

      @keyframes pulse-cta {
          0%, 100% {
              box-shadow: 0 0 0 0 rgba(212, 82, 31, 0.4);
          }
          50% {
              box-shadow: 0 0 0 10px rgba(212, 82, 31, 0);
          }
      }

      @keyframes slideIn {
          from {
              opacity: 0;
              transform: translateY(20px);
          }
          to {
              opacity: 1;
              transform: translateY(0);
          }
      }

      .btn-donate-cta {
          animation: pulse-cta 2s infinite;
      }

      .partner-badge {
          cursor: pointer;
          animation: slideIn 0.6s ease-out;
      }

      .partner-badge:hover {
          transform: translateY(-8px);
          box-shadow: 0 12px 40px rgba(0,0,0,0.15) !important;
      }

      .support-card {
          animation: slideIn 0.6s ease-out forwards;
      }

      .support-card:nth-child(1) {
          animation-delay: 0s;
      }

      .support-card:nth-child(2) {
          animation-delay: 0.1s;
      }

      .support-card:nth-child(3) {
          animation-delay: 0.2s;
      }

      /* Trust badges grid animation */
      @media (max-width: 768px) {
          .partner-badge {
              margin-bottom: 0.5rem;
          }
      }

      /* Testimonial cards animation */
      section#testimonials div[style*="display: grid"] > div {
          animation: slideIn 0.6s ease-out forwards;
      }

      section#testimonials div[style*="display: grid"] > div:nth-child(1) { animation-delay: 0.05s; }
      section#testimonials div[style*="display: grid"] > div:nth-child(2) { animation-delay: 0.1s; }
      section#testimonials div[style*="display: grid"] > div:nth-child(3) { animation-delay: 0.15s; }
      section#testimonials div[style*="display: grid"] > div:nth-child(4) { animation-delay: 0.2s; }
      section#testimonials div[style*="display: grid"] > div:nth-child(5) { animation-delay: 0.25s; }
      section#testimonials div[style*="display: grid"] > div:nth-child(6) { animation-delay: 0.3s; }

      /* Recent impact news animation */
      section#recent-impact div[style*="background: white"] > div {
          animation: slideIn 0.6s ease-out forwards;
      }

      section#recent-impact div[style*="background: white"] > div:nth-child(1) { animation-delay: 0.05s; }
      section#recent-impact div[style*="background: white"] > div:nth-child(2) { animation-delay: 0.1s; }
      section#recent-impact div[style*="background: white"] > div:nth-child(3) { animation-delay: 0.15s; }
      section#recent-impact div[style*="background: white"] > div:nth-child(4) { animation-delay: 0.2s; }

      /* Enhanced donation card hover effect */
      .support-card[style*="background: linear-gradient"]:hover {
          transform: translateY(-8px);
          box-shadow: 0 16px 48px rgba(0,0,0,0.2) !important;
      }
  </style>

