              <div class="mobile-section-content-clean" id="work-section">
                  <a href="chai-counters.html" class="mobile-link-clean">
                      <i class="fas fa-mug-hot"></i>
                      <span>Free Chai Counters</span>
                  </a>
                  <a href="community.html" class="mobile-link-clean">
                      <i class="fas fa-hands-helping"></i>
                      <span>Community Programs</span>
                  </a>
              </div>
          </div>

          <!-- Direct Links -->
          <a href="faq.html" class="mobile-menu-item-clean">
              <i class="fas fa-question-circle"></i>
              <span>FAQ</span>
          </a>

          <a href="contact.html" class="mobile-menu-item-clean">
              <i class="fas fa-envelope"></i>
              <span>Contact Us</span>
          </a>

          <!-- Social Links -->
          <div class="mobile-social-clean">
              <a href="https://www.facebook.com/DrRabinderNathFoundation/" target="_blank" aria-label="Facebook">
                  <i class="fab fa-facebook-f"></i>
              </a>
              <a href="https://www.linkedin.com/company/dr-rabinder-nath-foundation/" target="_blank" aria-label="LinkedIn">
                  <i class="fab fa-linkedin-in"></i>
