                      <a href="about.html" class="btn btn-primary">See Our Impact</a>
                      <a href="contact.html" class="btn btn-secondary">Join Us Today</a>
                  </div>
              </div>
              <div class="about-media">
                  <img src="https://res.cloudinary.com/dhupieu4x/image/upload/v1762599308/drnf-assets/drnf-assets/rabinder_nath2.1.jpg" alt="Dr. Rabinder Nath" class="about-image">
              </div>
          </div>
      </div>
  </section>

