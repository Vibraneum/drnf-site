      <div class="container">
          <div class="footer-content">
              <div class="footer-section">
                  <div class="footer-logo">
                      <img src="https://res.cloudinary.com/dhupieu4x/image/upload/v1762599287/drnf-assets/drnf-assets/DRNF_logo.jpg" alt="DRNF Logo">
