                  <span>About DRNF</span>
                  <i class="fas fa-chevron-down mobile-chevron"></i>
              </button>
              <div class="mobile-section-content-clean" id="about-section">
                  <a href="about.html" class="mobile-link-clean">
                      <i class="fas fa-heart"></i>
                      <span>Our Story & Mission</span>
                  </a>
                  <a href="dr-rabinder-nath.html" class="mobile-link-clean">
                      <i class="fas fa-user-md"></i>
                      <span>Dr. Rabinder Nath</span>
                  </a>
                  <a href="book.html" class="mobile-link-clean">
