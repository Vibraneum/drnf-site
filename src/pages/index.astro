              </div>
          </a>

          <!-- Desktop Navigation Links -->
          <ul class="nav-links-enhanced">
              <li><a href="index.html" class="nav-link-enhanced active">Home</a></li>

              <!-- About Dropdown -->
              <li>
                  <div class="nav-link-enhanced nav-dropdown-trigger" data-menu="about-mega-menu">
                      <span>About</span>
                      <svg class="chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
