---
import Layout from '../layouts/Layout.astro';
import AnimatedStats from '../components/react/AnimatedStats.tsx';
import TestimonialsCarousel from '../components/react/TestimonialsCarousel.tsx';
import BeforeAfterGallery from '../components/react/BeforeAfterGallery.tsx';
import CaseStudiesTeaser from '../components/react/CaseStudiesTeaser.tsx';
import NewsletterSignup from '../components/react/NewsletterSignup.tsx';

const pageTitle = 'Dr. Rabinder Nath Foundation | Community Service & Free Chai Counters in Hyderabad';
const pageDescription = 'Dr. Rabinder Nath Foundation serves the community through 2 free chai counters, sanitation workshops, environmental initiatives, and community support programs in Hyderabad. Join our mission of compassion and care.';
---

<Layout title={pageTitle} description={pageDescription} activePage="">
  
  <!-- Hero Section - Redesigned -->
  <section id="hero" class="hero-section-modern">
      <div class="hero-background-pattern"></div>
      <div class="container">
          <div class="hero-grid">
              <div class="hero-content-modern">
                  <div class="hero-badge">
                      <i class="fas fa-heart"></i>
                      <span>Serving Since 2016</span>
                  </div>
                  <h1 class="hero-title-modern">Dr. Rabinder Nath Foundation</h1>
                  <p class="hero-subtitle-modern">Serving 500-600 people daily through compassion, dignity, and community care</p>
                  <p class="hero-description-modern">Join our mission to empower Hyderabad through Free Chai Counters, Community Support, Education, and Environmental Initiatives</p>
                  <div class="hero-cta-modern">
                      <a href="/contact" class="btn-modern btn-primary-modern btn-donate-cta" style="background: linear-gradient(135deg, #d4521f 0%, #c14a1b 100%); border: 2px solid #d4521f; animation: pulse-cta 2s infinite;">
                          <i class="fas fa-heart"></i>
                          <span>Support Our Mission Now</span>
                      </a>
                      <a href="/about" class="btn-modern btn-secondary-modern">
                          <i class="fas fa-info-circle"></i>
                          <span>Learn Our Story</span>
                      </a>
                  </div>
                  <p style="margin-top: 1.5rem; font-size: 0.95rem; color: rgba(44, 85, 48, 0.8); text-align: center;">
                      <i class="fas fa-clock" style="color: #d4521f; margin-right: 0.5rem;"></i>
                      <strong>Limited Impact:</strong> We can only serve 500-600 people daily. Help us expand to reach more.
                  </p>
              </div>
              <div class="hero-stats-modern">
                  <figure style="margin-bottom: 2rem; border-radius: 12px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.15);">
                      <img src="https://res.cloudinary.com/dhupieu4x/image/upload/v1762599308/drnf-assets/drnf-assets/rabinder_nath2.1.jpg"
                           alt="DRNF Free Chai Counter at Banjara Hills serving tea 24/7 to homeless community and frontline workers in Hyderabad"
                           loading="eager"
                           style="width: 100%; height: auto; display: block;">
                      <figcaption style="padding: 1rem; background: white; font-size: 0.9rem; color: #666; text-align: center;">
                          Free Chai Counter at Banjara Hills - Serving 500-600 people daily
                      </figcaption>
                  </figure>
                  <div class="stat-card-modern">
                      <div class="stat-icon-modern">
                          <i class="fas fa-mug-hot"></i>
                      </div>
                      <div class="stat-number-modern">500-600</div>
                      <div class="stat-label-modern">People Served Daily</div>
                  </div>
                  <div class="stat-card-modern">
                      <div class="stat-icon-modern">
                          <i class="fas fa-calendar-alt"></i>
                      </div>
                      <div class="stat-number-modern">July 2021</div>
                      <div class="stat-label-modern">Free Chai Counter Started</div>
                  </div>
                  <div class="stat-card-modern">
                      <div class="stat-icon-modern">
                          <i class="fas fa-map-marker-alt"></i>
                      </div>
                      <div class="stat-number-modern">2</div>
                      <div class="stat-label-modern">Active Locations</div>
                  </div>
                  <div class="stat-card-modern">
                      <div class="stat-icon-modern">
                          <i class="fas fa-users"></i>
                      </div>
                      <div class="stat-number-modern">70+</div>
                      <div class="stat-label-modern">Lives Impacted</div>
                  </div>
              </div>
          </div>
      </div>
      <div class="scroll-indicator-modern">
          <span>Scroll to explore</span>
          <div class="scroll-arrow-modern"></div>
      </div>
  </section>

  <!-- Trust & Partnership Section -->
  <section id="trust-badges" class="section" style="background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%); padding: 3rem 0;">
      <div class="container">
          <div style="text-align: center; margin-bottom: 3rem;">
              <h2 class="section-title" style="color: var(--primary-color); margin-bottom: 0.5rem;">Trusted by Leading Organizations</h2>
              <p class="section-subtitle" style="color: var(--text-secondary);">Partners and supporters who believe in our mission</p>
          </div>

          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 2.5rem; align-items: center; max-width: 1000px; margin: 0 auto;">
              <!-- LooCafe Badge -->
              <div style="background: white; padding: 2.5rem; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); text-align: center; transition: transform 0.3s ease, box-shadow 0.3s ease;" class="partner-badge">
                  <div style="font-size: 3.5rem; margin-bottom: 1rem; color: var(--primary-color);">
                      <i class="fas fa-restroom"></i>
                  </div>
                  <h3 style="color: var(--primary-color); font-size: 1.3rem; margin-bottom: 0.5rem; font-weight: 600;">LooCafe Partnership</h3>
                  <p style="color: var(--text-secondary); font-size: 0.9rem; line-height: 1.6;">
                      Infrastructure partner for 270+ sanitation facilities across Hyderabad
                  </p>
                  <div style="margin-top: 1rem; padding-top: 1rem; border-top: 2px solid #f0f0f0;">
                      <span style="display: inline-block; background: rgba(44, 85, 48, 0.1); color: var(--primary-color); padding: 0.5rem 1rem; border-radius: 20px; font-size: 0.85rem; font-weight: 600;">
                          <i class="fas fa-check-circle"></i> Verified Partnership
                      </span>
                  </div>
              </div>

              <!-- Ixora Group Badge -->
              <div style="background: white; padding: 2.5rem; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); text-align: center; transition: transform 0.3s ease, box-shadow 0.3s ease;" class="partner-badge">
                  <div style="font-size: 3.5rem; margin-bottom: 1rem; color: var(--primary-color);">
                      <i class="fas fa-building"></i>
                  </div>
                  <h3 style="color: var(--primary-color); font-size: 1.3rem; margin-bottom: 0.5rem; font-weight: 600;">Ixora Group</h3>
                  <p style="color: var(--text-secondary); font-size: 0.9rem; line-height: 1.6;">
                      Institutional operational support and administrative resources
                  </p>
                  <div style="margin-top: 1rem; padding-top: 1rem; border-top: 2px solid #f0f0f0;">
                      <span style="display: inline-block; background: rgba(44, 85, 48, 0.1); color: var(--primary-color); padding: 0.5rem 1rem; border-radius: 20px; font-size: 0.85rem; font-weight: 600;">
                          <i class="fas fa-check-circle"></i> Corporate Sponsor
                      </span>
                  </div>
              </div>

              <!-- Gates Foundation Badge -->
              <div style="background: white; padding: 2.5rem; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); text-align: center; transition: transform 0.3s ease, box-shadow 0.3s ease;" class="partner-badge">
                  <div style="font-size: 3.5rem; margin-bottom: 1rem; color: var(--primary-color);">
                      <i class="fas fa-globe"></i>
                  </div>
                  <h3 style="color: var(--primary-color); font-size: 1.3rem; margin-bottom: 0.5rem; font-weight: 600;">Gates Foundation Backed</h3>
                  <p style="color: var(--text-secondary); font-size: 0.9rem; line-height: 1.6;">
                      Working within ecosystem funded for sanitation and health excellence
                  </p>
                  <div style="margin-top: 1rem; padding-top: 1rem; border-top: 2px solid #f0f0f0;">
                      <span style="display: inline-block; background: rgba(44, 85, 48, 0.1); color: var(--primary-color); padding: 0.5rem 1rem; border-radius: 20px; font-size: 0.85rem; font-weight: 600;">
                          <i class="fas fa-check-circle"></i> Aligned Mission
                      </span>
                  </div>
              </div>
          </div>

          <style>
              .partner-badge {
                  cursor: pointer;
              }
              .partner-badge:hover {
                  transform: translateY(-8px);
                  box-shadow: 0 12px 40px rgba(0,0,0,0.15) !important;
              }
              @keyframes pulse-cta {
                  0%, 100% {
                      box-shadow: 0 0 0 0 rgba(212, 82, 31, 0.4);
                  }
                  50% {
                      box-shadow: 0 0 0 10px rgba(212, 82, 31, 0);
                  }
              }
          </style>
      </div>
  </section>

  <!-- Animated Stats Section -->
  <AnimatedStats client:load />

  <!-- Social Media Section -->
  <section id="socials" class="section">
      <div class="container">
          <h2 class="section-title">Connect With Us</h2>
          <div class="social-links">
              <a href="https://www.facebook.com/DrRabinderNathFoundation/" target="_blank" class="social-card">
                  <div class="social-icon facebook">
                      <i class="fab fa-facebook-f"></i>
                  </div>
                  <div class="social-content">
                      <h3>Facebook</h3>
                      <p>Follow our daily updates and community stories</p>
                      <span class="social-handle">@DrRabinderNathFoundation</span>
                  </div>
              </a>
              <a href="https://www.linkedin.com/company/dr-rabinder-nath-foundation/mycompany/" target="_blank" class="social-card">
                  <div class="social-icon linkedin">
                      <i class="fab fa-linkedin-in"></i>
                  </div>
                  <div class="social-content">
                      <h3>LinkedIn</h3>
                      <p>Professional updates and partnership opportunities</p>
                      <span class="social-handle">Dr. Rabinder Nath Foundation</span>
                  </div>
              </a>
          </div>
      </div>
  </section>

  <!-- Who We Are Section -->
  <section id="about" class="section about-section">
      <div class="container">
          <div class="about-content">
              <div class="about-text">
                  <h2 class="section-title">Who We Are</h2>
                  <p class="about-description">
                      Created in the memory of the Late Vijayshree Dr. Rabinder Nath, the Dr. Rabinder Nath Foundation honors his legacy as a Dental Surgeon, Social Worker, and Pioneer in Hyderabad and across India.
                  </p>
                  <p>
                      A beloved figure cherished by families across the city, our foundation was established by his well-wishers and community to continue his mission of service and compassion. Today, we serve through free chai counters, community support programs, educational workshops, and environmental initiatives.
                  </p>
                  <div class="about-highlights">
                      <div class="highlight-item">
                          <i class="fas fa-heart"></i>
                          <span>Community Service</span>
                      </div>
                      <div class="highlight-item">
                          <i class="fas fa-hands-helping"></i>
                          <span>Social Impact</span>
                      </div>
                      <div class="highlight-item">
                          <i class="fas fa-leaf"></i>
                          <span>Environmental Care</span>
                      </div>
                      <div class="highlight-item">
                          <i class="fas fa-graduation-cap"></i>
                          <span>Education & Workshops</span>
                      </div>
                  </div>
                  <div class="hero-cta" style="margin-top: 2rem;">
                      <a href="/about" class="btn btn-primary">See Our Impact</a>
                      <a href="/contact" class="btn btn-secondary">Join Us Today</a>
                  </div>
              </div>
              <div class="about-media">
                  <img src="https://res.cloudinary.com/dhupieu4x/image/upload/v1762599308/drnf-assets/drnf-assets/rabinder_nath2.1.jpg" alt="Dr. Rabinder Nath" class="about-image">
              </div>
          </div>
      </div>
  </section>

  <!-- Recognition & Awards Section -->
  <section id="awards" class="section" style="background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);">
      <div class="container">
          <h2 class="section-title">Recognition & Impact</h2>
          <p class="section-subtitle">
              Our community service work has been recognized for environmental and social excellence
          </p>

          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2.5rem; margin-top: 3rem;">
              <figure style="background: white; padding: 2rem; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.1); text-align: center;">
                  <img src="/images/awards/5-star-garbage-free-city-award.jpg"
                       alt="DRNF receives 5-star Garbage Free City Award for environmental excellence and waste management through LooCafe partnership"
                       loading="lazy"
                       style="width: 100%; height: auto; border-radius: 12px; margin-bottom: 1.5rem;">
                  <figcaption>
                      <h3 style="color: var(--primary-color); margin-bottom: 0.5rem; font-size: 1.3rem;">5-Star Garbage Free City Award</h3>
                      <p style="color: var(--text-secondary); font-size: 0.95rem; line-height: 1.6;">
                          Recognized for environmental excellence and waste management initiatives through our LooCafe partnership
                      </p>
                  </figcaption>
              </figure>

              <figure style="background: white; padding: 2rem; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.1); text-align: center;">
                  <img src="/images/awards/team-receiving-award.jpg"
                       alt="DRNF team receiving recognition award for community service and social impact in Hyderabad"
                       loading="lazy"
                       style="width: 100%; height: auto; border-radius: 12px; margin-bottom: 1.5rem;">
                  <figcaption>
                      <h3 style="color: var(--primary-color); margin-bottom: 0.5rem; font-size: 1.3rem;">Community Service Recognition</h3>
                      <p style="color: var(--text-secondary); font-size: 0.95rem; line-height: 1.6;">
                          Our team receiving recognition for dedication to community service and social impact
                      </p>
                  </figcaption>
              </figure>
          </div>
      </div>
  </section>

  <!-- Our Initiatives Section -->
  <section id="initiatives" class="section">
      <div class="container">
          <h2 class="section-title">Our Initiatives</h2>
          <p class="section-subtitle">
              Making a difference through dedicated community programs
          </p>

          <div class="initiatives-grid">
              <!-- Card 1: Free Chai Counters -->
              <div class="initiative-card">
                  <div class="initiative-icon">
                      <i class="fas fa-coffee"></i>
                  </div>
                  <h3>Free Chai Counters</h3>
                  <p>Operating 24/7 with dignity at its heart. We serve hot tea and meals to those in need, creating a safe space for homeless individuals and supporting cancer patients' families.</p>
                  <div class="initiative-stats">
                      <span class="stat-badge">500-600 People Daily</span>
                      <span class="stat-badge">2 Locations</span>
                      <span class="stat-badge">Since July 2021</span>
                  </div>
                  <a href="/chai-counters" class="btn btn-primary">Join Free Chai Service</a>
              </div>

              <!-- Card 2: Community Support -->
              <div class="initiative-card">
                  <div class="initiative-icon">
                      <i class="fas fa-hands-helping"></i>
                  </div>
                  <h3>Community Support</h3>
                  <p>Building stronger neighborhoods through regular donation drives and targeted support programs. We provide essential supplies and meaningful assistance to families in need.</p>
                  <div class="initiative-stats">
                      <span class="stat-badge">Ongoing Impact Programs</span>
                  </div>
                  <a href="/community" class="btn btn-primary">Read Success Stories</a>
              </div>

              <!-- Card 3: Education Workshops -->
              <div class="initiative-card">
                  <div class="initiative-icon">
                      <i class="fas fa-graduation-cap"></i>
                  </div>
                  <h3>Education Workshops</h3>
                  <p>Empowering young minds through weekly workshops covering sanitation, health, and life skills. We've impacted 70+ students, building futures and stronger communities.</p>
                  <div class="initiative-stats">
                      <span class="stat-badge">70+ Students Reached</span>
                  </div>
                  <a href="/community#workshops" class="btn btn-primary">Support Students</a>
              </div>

              <!-- Card 4: Environmental Care -->
              <div class="initiative-card">
                  <div class="initiative-icon">
                      <i class="fas fa-leaf"></i>
                  </div>
                  <h3>Environment & Welfare</h3>
                  <p>Protecting our planet and its creatures through tree plantation drives and animal welfare programs. Every action counts toward a sustainable, compassionate future.</p>
                  <div class="initiative-stats">
                      <span class="stat-badge">Tree Drives & Animal Care</span>
                  </div>
                  <a href="/community#environment" class="btn btn-primary">Help Our Planet</a>
              </div>
          </div>
      </div>
  </section>

  <!-- Impact Section -->
  <section id="impact" class="section impact-section">
      <div class="container">
          <h2 class="section-title">Our Impact</h2>
          <p class="section-subtitle">
              Measurable change through dedicated service | <a href="/transparency" style="color: var(--primary-color); text-decoration: underline;">See Full Transparency Report</a>
          </p>

          <div class="impact-grid">
              <div class="impact-stat">
                  <div class="impact-icon">
                      <i class="fas fa-coffee"></i>
                  </div>
                  <div class="impact-number">500-600</div>
                  <div class="impact-label">People Served Daily</div>
              </div>

              <div class="impact-stat">
                  <div class="impact-icon">
                      <i class="fas fa-briefcase"></i>
                  </div>
                  <div class="impact-number">70+</div>
                  <div class="impact-label">Jobs Created</div>
              </div>

              <div class="impact-stat">
                  <div class="impact-icon">
                      <i class="fas fa-map-marker-alt"></i>
                  </div>
                  <div class="impact-number">2</div>
                  <div class="impact-label">Active Chai Counters</div>
              </div>

              <div class="impact-stat">
                  <div class="impact-icon">
                      <i class="fas fa-network-wired"></i>
                  </div>
                  <div class="impact-number">30</div>
                  <div class="impact-label">LooCafes in Pilot Program</div>
              </div>

              <div class="impact-stat">
                  <div class="impact-icon">
                      <i class="fas fa-graduation-cap"></i>
                  </div>
                  <div class="impact-number">70</div>
                  <div class="impact-label">Students Supported</div>
              </div>

              <div class="impact-stat">
                  <div class="impact-icon">
                      <i class="fas fa-clock"></i>
                  </div>
                  <div class="impact-number">24/7</div>
                  <div class="impact-label">Service Availability</div>
              </div>
          </div>

          <!-- Cost-Effectiveness Quick View -->
          <div style="background: linear-gradient(135deg, rgba(102,126,234,0.1) 0%, rgba(118,75,162,0.1) 100%); padding: 3rem; border-radius: 20px; margin-top: 4rem; text-align: center;">
              <h3 style="font-size: 2rem; color: var(--primary-color); margin-bottom: 2rem;">Cost-Effectiveness</h3>
              <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 2rem;">
                  <div>
                      <div style="font-size: 3rem; font-weight: 700; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">₹2</div>
                      <div style="font-size: 1.1rem; color: var(--text-secondary); margin-top: 0.5rem;">Per Cup of Chai</div>
                  </div>
                  <div>
                      <div style="font-size: 3rem; font-weight: 700; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">₹1,000</div>
                      <div style="font-size: 1.1rem; color: var(--text-secondary); margin-top: 0.5rem;">Serves 500 People</div>
                  </div>
                  <div>
                      <div style="font-size: 3rem; font-weight: 700; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">₹30K</div>
                      <div style="font-size: 1.1rem; color: var(--text-secondary); margin-top: 0.5rem;">One Month Operation</div>
                  </div>
              </div>
              <a href="/transparency#cost-effectiveness" style="display: inline-block; margin-top: 2rem; padding: 1rem 2rem; background: var(--primary-color); color: white; border-radius: 8px; text-decoration: none; font-weight: 600;">See Full Cost Analysis</a>
          </div>
      </div>
  </section>

  <!-- Real Impact Stories & Testimonials Section -->
  <section id="testimonials" class="section" style="background: linear-gradient(135deg, rgba(44, 85, 48, 0.05) 0%, rgba(212, 82, 31, 0.05) 100%);">
      <div class="container">
          <h2 class="section-title" style="color: var(--primary-color); margin-bottom: 0.5rem;">Stories of Impact</h2>
          <p class="section-subtitle">Real voices from the people and organizations we serve</p>

          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2.5rem; margin-top: 3rem;">
              <!-- Testimonial 1: Beneficiary -->
              <div style="background: white; padding: 2.5rem; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); border-left: 5px solid var(--primary-color); position: relative;">
                  <div style="display: flex; align-items: center; margin-bottom: 1.5rem;">
                      <div style="font-size: 2rem; color: #f39c12; margin-right: 0.5rem;">
                          <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
                      </div>
                  </div>
                  <p style="font-size: 1.1rem; color: var(--text-secondary); line-height: 1.8; margin-bottom: 1.5rem; font-style: italic;">
                      "The free chai counter has been a lifesaver for me. On cold nights when I had nowhere warm to go, DRNF provided not just chai but dignity and respect. They treat you like a human being, not a number."
                  </p>
                  <div style="display: flex; align-items: center; padding-top: 1.5rem; border-top: 2px solid #f0f0f0;">
                      <div style="background: linear-gradient(135deg, var(--primary-color) 0%, #3d7842 100%); color: white; width: 50px; height: 50px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 600; margin-right: 1rem; font-size: 1.2rem;">
                          RS
                      </div>
                      <div>
                          <h4 style="color: var(--primary-color); margin: 0; font-weight: 600;">Ramesh</h4>
                          <p style="color: var(--text-secondary); margin: 0.25rem 0 0 0; font-size: 0.9rem;">Regular Chai Counter Visitor</p>
                      </div>
                  </div>
              </div>

              <!-- Testimonial 2: Educational Partner -->
              <div style="background: white; padding: 2.5rem; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); border-left: 5px solid var(--primary-color); position: relative;">
                  <div style="display: flex; align-items: center; margin-bottom: 1.5rem;">
                      <div style="font-size: 2rem; color: #f39c12; margin-right: 0.5rem;">
                          <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
                      </div>
                  </div>
                  <p style="font-size: 1.1rem; color: var(--text-secondary); line-height: 1.8; margin-bottom: 1.5rem; font-style: italic;">
                      "DRNF's education workshops have transformed the lives of our orphanage students. The knowledge they share about hygiene and health has improved quality of life for all 70+ children we support."
                  </p>
                  <div style="display: flex; align-items: center; padding-top: 1.5rem; border-top: 2px solid #f0f0f0;">
                      <div style="background: linear-gradient(135deg, var(--primary-color) 0%, #3d7842 100%); color: white; width: 50px; height: 50px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 600; margin-right: 1rem; font-size: 1rem;">
                          AS
                      </div>
                      <div>
                          <h4 style="color: var(--primary-color); margin: 0; font-weight: 600;">Asha Setty</h4>
                          <p style="color: var(--text-secondary); margin: 0.25rem 0 0 0; font-size: 0.9rem;">Abhi Sai Datta Trust Director</p>
                      </div>
                  </div>
              </div>

              <!-- Testimonial 3: LooCafe Partner -->
