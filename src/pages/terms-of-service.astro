---
import Layout from '../layouts/Layout.astro';

const pageTitle = 'Terms of Service - Dr. Rabinder Nath Foundation';
const pageDescription = 'Terms of Service for Dr. Rabinder Nath Foundation website, including automatic marketing opt-in for inquiries and communications.';
---

<Layout title={pageTitle} description={pageDescription}>
  
<!-- Header -->
        <div class="terms-header" data-aos="fade-up">
            <h1>Terms of Service</h1>
            <p><strong>Last Updated:</strong> January 2025</p>
        </div>

        <!-- Content -->
        <div class="terms-content">
            <!-- Section 1 -->
            <div class="terms-section" data-aos="fade-up">
                <h2>1. Agreement to Terms</h2>
                <p>
                    By accessing or using the Dr. Rabinder Nath Foundation website (<strong>drnf.org</strong>), you agree to be bound by these Terms of Service. If you do not agree to these terms, please do not use our website.
                </p>
                <p>
                    Dr. Rabinder Nath Foundation ("DRNF", "we", "us", or "our") reserves the right to modify these terms at any time. Your continued use of the website constitutes acceptance of any changes.
                </p>
            </div>

            <!-- Section 2 -->
            <div class="terms-section" data-aos="fade-up">
                <h2>2. About DRNF</h2>
                <p>
                    Dr. Rabinder Nath Foundation is a non-profit community service organization founded in 2020, dedicated to:
                </p>
                <ul>
                    <li>Operating free chai counters for the homeless and underprivileged</li>
                    <li>Community support programs and donation drives</li>
                    <li>Sanitation and education workshops</li>
                    <li>Environmental conservation and animal welfare</li>
                    <li>Creating meaningful employment opportunities</li>
                </ul>
            </div>

            <!-- Section 3 - Highlighted -->
            <div class="terms-section" data-aos="fade-up">
                <div class="highlight-box">
                    <h3>3. Contact Form Submissions & Communication Consent</h3>
                    <p><strong style="color: #d97706;">IMPORTANT - Automatic Opt-In Notice:</strong></p>
                    <p>
                        By submitting any contact form, inquiry, volunteer registration, or providing your contact information on our website, you explicitly agree to the following:
                    </p>
                    <ul style="margin-top: 20px;">
                        <li>
                            <strong>Automatic Subscription to Updates:</strong> You are automatically subscribed to receive updates, newsletters, event announcements, volunteer opportunities, impact reports, and other communications from DRNF via email, SMS, WhatsApp, or other channels.
                        </li>
                        <li>
                            <strong>Consent to Contact:</strong> You authorize DRNF and its representatives to contact you regarding your inquiry, volunteer opportunities, events, fundraising campaigns, and community programs.
                        </li>
                        <li>
                            <strong>Data Collection:</strong> We will collect, store, and process your contact information (name, email, phone, message content) for communication and organizational purposes.
                        </li>
                        <li>
                            <strong>Partner Communications:</strong> We may share relevant updates from our partners (LooCafe, Ixora Group, Abhi Sai Datta Trust) when appropriate.
                        </li>
                    </ul>
                    <p style="margin-top: 25px;">
                        <strong>Right to Unsubscribe:</strong> You may opt-out of communications at any time by:
                    </p>
                    <ul style="margin-top: 10px;">
                        <li>Clicking the "Unsubscribe" link in any email</li>
                        <li>Replying "STOP" to any SMS message</li>
                        <li>Emailing us at: <a href="mailto:info@drnf.org" style="color: #2c5530; text-decoration: underline;">info@drnf.org</a></li>
                        <li>Calling us at: <a href="tel:+919966906781" style="color: #2c5530; text-decoration: underline;">+91 9966906781</a></li>
                    </ul>
                </div>
            </div>

            <!-- Section 4 -->
            <div class="terms-section" data-aos="fade-up">
                <h2>4. Data Collection and Privacy</h2>
                <p>
                    We collect the following information when you interact with our website:
                </p>
                <ul>
                    <li><strong>Personal Information:</strong> Name, email address, phone number</li>
                    <li><strong>Inquiry Details:</strong> Area of interest (volunteering, partnership, donation, etc.), message content</li>
                    <li><strong>Technical Data:</strong> IP address, browser type, device information, timestamp</li>
                </ul>
                <p>
                    For detailed information on how we handle your data, please review our <a href="/privacy-policy" style="color: #2c5530; font-weight: 600; text-decoration: underline;">Privacy Policy</a>.
                </p>
            </div>

            <!-- Section 5 -->
            <div class="terms-section" data-aos="fade-up">
                <h2>5. Use of Website</h2>
                <p>You agree to use our website only for lawful purposes. You agree not to:</p>
                <ul>
                    <li>Submit false, misleading, or fraudulent information</li>
                    <li>Use automated systems (bots, scrapers) to access the website</li>
                    <li>Attempt to gain unauthorized access to any systems or data</li>
                    <li>Transmit viruses, malware, or harmful code</li>
                    <li>Engage in any activity that disrupts or interferes with the website</li>
                    <li>Use the website for spam or malicious purposes</li>
                </ul>
            </div>

            <!-- Section 6 -->
            <div class="terms-section" data-aos="fade-up">
                <h2>6. Volunteer and Donation Activities</h2>
                <p>
                    If you choose to volunteer with DRNF or make donations:
                </p>
                <ul>
                    <li>All volunteer activities are subject to availability and organizational needs</li>
                    <li>Donations are voluntary and non-refundable unless required by law</li>
                    <li>DRNF reserves the right to refuse or return donations at its discretion</li>
                    <li>You will receive communication regarding volunteer opportunities and impact updates</li>
                    <li>DRNF is not responsible for third-party donation platforms or payment processors</li>
                </ul>
            </div>

            <!-- Section 7 -->
            <div class="terms-section" data-aos="fade-up">
                <h2>7. Intellectual Property</h2>
                <p>
                    All content on the DRNF website, including text, graphics, logos, images, videos, and software, is the property of Dr. Rabinder Nath Foundation or its licensors and is protected by copyright and trademark laws.
                </p>
                <p>
                    You may not reproduce, distribute, modify, or create derivative works from any content without our express written permission.
                </p>
            </div>

            <!-- Section 8 -->
            <div class="terms-section" data-aos="fade-up">
                <h2>8. Third-Party Links and Partnerships</h2>
                <p>
                    Our website contains links to third-party websites (including LooCafe, Ixora Group, and partner organizations). We are not responsible for:
                </p>
                <ul>
                    <li>Content, accuracy, or practices of third-party websites</li>
                    <li>Privacy policies of external sites</li>
                    <li>Products or services offered by third parties</li>
                </ul>
                <p>
                    <strong>Key Partners:</strong>
                </p>
                <ul>
                    <li><strong>LooCafe:</strong> Strategic partner for chai counter locations (270+ network)</li>
                    <li><strong>Ixora Group:</strong> Institutional support and resources</li>
                    <li><strong>Abhi Sai Datta Trust:</strong> Educational workshop partnership</li>
                </ul>
            </div>

            <!-- Section 9 -->
            <div class="terms-section" data-aos="fade-up">
                <h2>9. Disclaimer of Warranties</h2>
                <p>
                    The DRNF website and information provided are on an "AS IS" and "AS AVAILABLE" basis. We make no warranties, expressed or implied, regarding:
                </p>
                <ul>
                    <li>Accuracy, completeness, or reliability of website content</li>
                    <li>Uninterrupted or error-free operation of the website</li>
                    <li>Security of data transmission over the internet</li>
                    <li>Availability of volunteer opportunities or programs</li>
                </ul>
            </div>

            <!-- Section 10 -->
            <div class="terms-section" data-aos="fade-up">
                <h2>10. Limitation of Liability</h2>
                <p>
                    To the maximum extent permitted by law, DRNF shall not be liable for any indirect, incidental, special, consequential, or punitive damages arising from your use of the website.
                </p>
            </div>

            <!-- Section 11 -->
            <div class="terms-section" data-aos="fade-up">
                <h2>11. Governing Law</h2>
                <p>
                    These Terms of Service shall be governed by and construed in accordance with the laws of India. Any disputes arising from these terms shall be subject to the exclusive jurisdiction of the courts in Hyderabad, Telangana, India.
                </p>
            </div>

            <!-- Section 12 - Contact -->
            <div class="terms-section" data-aos="fade-up">
                <div class="contact-box">
                    <h2 style="color: var(--primary-color); margin-top: 0;">12. Contact Information</h2>
                    <p>
                        If you have any questions about these Terms of Service, please contact us:
                    </p>
                    <p style="margin-top: 25px;">
                        <strong>Dr. Rabinder Nath Foundation</strong><br>
                        Door No: 8, 2-293/82/J/A/101<br>
                        Journalist Colony, Jubilee Hills<br>
                        Hyderabad, Telangana 500033, India
                    </p>
                    <p style="margin-top: 20px;">
                        <strong>Email:</strong> <a href="mailto:info@drnf.org" style="color: #2c5530; text-decoration: underline;">info@drnf.org</a><br>
                        <strong>Phone:</strong> <a href="tel:+919966906781" style="color: #2c5530; text-decoration: underline;">+91 9966906781</a><br>
                        <strong>WhatsApp:</strong> <a href="https://wa.me/919966906781" target="_blank" rel="noopener noreferrer" style="color: #2c5530; text-decoration: underline;">+91 9966906781</a>
                    </p>
                </div>
            </div>

            <!-- Section 13 -->
            <div class="terms-section" data-aos="fade-up">
                <h2>13. Changes to Terms</h2>
                <p>
                    We reserve the right to modify these Terms of Service at any time. Changes will be effective immediately upon posting to the website. Your continued use of the website after changes constitutes acceptance of the modified terms.
                </p>
                <p>
                    We encourage you to review these terms periodically for any updates.
                </p>
            </div>

            <!-- Section 14 -->
            <div class="terms-section" data-aos="fade-up">
                <h2>14. Acknowledgment</h2>
                <p>
                    By using this website and submitting any forms, you acknowledge that you have read, understood, and agree to be bound by these Terms of Service and our Privacy Policy.
                </p>
            </div>

            <!-- Footer Links -->
            <div class="footer-links" data-aos="fade-up">
                <p>Related Documents:</p>
                <a href="/privacy-policy">Privacy Policy</a>
                <span style="color: var(--text-secondary);">|</span>
                <a href="/contact">Contact Us</a>
                <span style="color: var(--text-secondary);">|</span>
                <a href="/">Back to Home</a>
            </div>
        </div>
    </div>

  <!-- Back to Top Button -->
  <button class="back-to-top" id="backToTop" aria-label="Back to top">
    <i class="fas fa-arrow-up"></i>
  </button>

</Layout>

<script>
  // Current year in footer
  if (typeof document !== 'undefined') {
    const yearElement = document.getElementById('current-year');
    if (yearElement) {
      yearElement.textContent = new Date().getFullYear();
    }
  }
</script>
