---
import Layout from '../layouts/Layout.astro';
import NewsletterSignup from '../components/react/NewsletterSignup.tsx';

const pageTitle = 'Community Initiatives | Dr. Rabinder Nath Foundation';
const pageDescription = "DRNF's community initiatives include regular donation drives, sanitation and education workshops, environmental conservation, and animal welfare programs in Hyderabad.";
---

<Layout title={pageTitle} description={pageDescription} activePage="community">
  
<section class="page-hero">
        <div class="container">
            <h1 data-aos="fade-up">Community Initiatives</h1>
            <p data-aos="fade-up" data-aos-delay="200">Building sustainable impact through community support, education, and environmental care</p>
        </div>
    </section>

    <!-- Families Counter Section -->
    <section class="section families-counter-section">
        <div class="container">
            <div class="counter-card" data-aos="zoom-in">
                <div class="counter-content">
                    <div class="counter-icon">
                        <i class="fas fa-home"></i>
                    </div>
                    <h2>Families We've Helped</h2>
                    <div class="counter-display">
                        <span class="counter-number" data-target="450" id="familiesCounter">0</span>
                        <span class="counter-label">Families Supported</span>
                    </div>
                    <p class="counter-subtitle">Through direct assistance, emergency support, and sustainable programs</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Impact Metrics Section -->
    <section class="section impact-metrics-section">
        <div class="container">
            <h2 class="section-title" data-aos="fade-up">Our Community Impact</h2>

            <div class="metrics-grid">
                <div class="metric-card" data-aos="fade-up" data-aos-delay="0">
                    <div class="metric-header">
                        <i class="fas fa-rupee-sign"></i>
                        <h3>Financial Assistance</h3>
                    </div>
                    <div class="progress-bar">
                        <div class="progress-fill" style="width: 100%; background: linear-gradient(90deg, #2c5530 0%, #45b7d1 100%);" data-target="500000"></div>
                    </div>
                    <div class="metric-details">
                        <span class="metric-value">₹5,00,000+</span>
                        <span class="metric-description">Direct assistance distributed</span>
                    </div>
                </div>

                <div class="metric-card" data-aos="fade-up" data-aos-delay="100">
                    <div class="metric-header">
                        <i class="fas fa-graduation-cap"></i>
                        <h3>Students Supported</h3>
                    </div>
                    <div class="progress-bar">
                        <div class="progress-fill" style="width: 100%; background: linear-gradient(90deg, #2c5530 0%, #f39c12 100%);" data-target="70"></div>
                    </div>
                    <div class="metric-details">
                        <span class="metric-value">70+</span>
                        <span class="metric-description">Educational support & scholarships</span>
                    </div>
                </div>

                <div class="metric-card" data-aos="fade-up" data-aos-delay="200">
                    <div class="metric-header">
                        <i class="fas fa-briefcase"></i>
                        <h3>Jobs Created</h3>
                    </div>
                    <div class="progress-bar">
                        <div class="progress-fill" style="width: 100%; background: linear-gradient(90deg, #2c5530 0%, #2ecc71 100%);" data-target="70"></div>
                    </div>
                    <div class="metric-details">
                        <span class="metric-value">70+</span>
                        <span class="metric-description">Employment opportunities created</span>
                    </div>
                </div>

                <div class="metric-card" data-aos="fade-up" data-aos-delay="300">
                    <div class="metric-header">
                        <i class="fas fa-users"></i>
                        <h3>Team Members</h3>
                    </div>
                    <div class="progress-bar">
                        <div class="progress-fill" style="width: 100%; background: linear-gradient(90deg, #2c5530 0%, #9b59b6 100%);" data-target="40"></div>
                    </div>
                    <div class="metric-details">
                        <span class="metric-value">40+</span>
                        <span class="metric-description">Full-time associates & volunteers</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Donations Section -->
    <section id="donations" class="section donations-section">
        <div class="container">
            <h2 class="section-title" data-aos="fade-up">Community Initiatives</h2>

            <!-- Community Work Overview -->
            <div class="community-overview" data-aos="fade-up" data-aos-delay="100">
                <div class="overview-content">
                    <h3>Ongoing Community Support</h3>
                    <p>We are actively interested in and continuously run various donation drives and community support initiatives. Our foundation believes in sustainable, impactful giving that creates lasting change in our community.</p>

                    <div class="initiative-stats">
                        <div class="stat-card">
                            <div class="stat-icon">
                                <i class="fas fa-heart"></i>
                            </div>
                            <h4>Regular Drives</h4>
                            <p>Continuous community support programs</p>
                        </div>

                        <div class="stat-card">
                            <div class="stat-icon">
                                <i class="fas fa-hands-helping"></i>
                            </div>
                            <h4>Sustainable Impact</h4>
                            <p>Focus on long-term community development</p>
                        </div>

                        <div class="stat-card">
                            <div class="stat-icon">
                                <i class="fas fa-users"></i>
                            </div>
                            <h4>Community Centered</h4>
                            <p>Direct engagement with local families</p>
                        </div>
                    </div>

                    <div class="subtle-note">
                        <p><small>Past initiatives have facilitated support worth approximately ₹5,00,000 through various community programs</small></p>
                    </div>
                </div>
            </div>

            <!-- Timeline of Recent Activities -->
            <div class="timeline-section" data-aos="fade-up" data-aos-delay="200">
                <h3 class="timeline-title">Recent Community Support Timeline</h3>
                <div class="timeline">
                    <div class="timeline-item" data-aos="fade-left" data-aos-delay="0">
                        <div class="timeline-marker"></div>
                        <div class="timeline-content">
                            <div class="timeline-date">November 2024</div>
                            <h4>Emergency Winter Relief Program</h4>
                            <p>Distributed winter clothing and blankets to 200+ homeless individuals across Hyderabad. Provided meal vouchers at LooCafe locations worth ₹50,000.</p>
                            <div class="timeline-impact">Impact: 200+ lives supported</div>
                        </div>
                    </div>

                    <div class="timeline-item" data-aos="fade-left" data-aos-delay="100">
                        <div class="timeline-marker"></div>
                        <div class="timeline-content">
                            <div class="timeline-date">September 2024</div>
                            <h4>Education Scholarship Drive</h4>
                            <p>Provided educational scholarships and study materials to 35 students from underprivileged families. Partnership with Abhi Sai Datta Trust expanded to include vocational training.</p>
                            <div class="timeline-impact">Impact: 35 students advancing education</div>
                        </div>
                    </div>

                    <div class="timeline-item" data-aos="fade-left" data-aos-delay="200">
                        <div class="timeline-marker"></div>
                        <div class="timeline-content">
                            <div class="timeline-date">July 2024</div>
                            <h4>Medical Emergency Fund Launch</h4>
                            <p>Established emergency medical fund to support families facing health crises. Distributed ₹1,25,000 to 15 families for critical medical treatments.</p>
                            <div class="timeline-impact">Impact: 15 families received life-saving care</div>
                        </div>
                    </div>

                    <div class="timeline-item" data-aos="fade-left" data-aos-delay="300">
                        <div class="timeline-marker"></div>
                        <div class="timeline-content">
                            <div class="timeline-date">May 2024</div>
                            <h4>Sanitation & Health Awareness Campaign</h4>
                            <p>Conducted 12 workshops on sanitation and hygiene across 4 communities. Reached 150+ residents with preventive health education and free health check-ups.</p>
                            <div class="timeline-impact">Impact: 150+ beneficiaries educated</div>
                        </div>
                    </div>

                    <div class="timeline-item" data-aos="fade-left" data-aos-delay="400">
                        <div class="timeline-marker"></div>
                        <div class="timeline-content">
                            <div class="timeline-date">March 2024</div>
                            <h4>Family Assistance Program Expanded</h4>
                            <p>Extended direct family assistance to 50 new families. Program now includes meal support, utility payments, and emergency financial aid.</p>
                            <div class="timeline-impact">Impact: 50 families secured</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Success Stories Section -->
            <div class="success-stories-section" data-aos="fade-up" data-aos-delay="300">
                <h3 class="stories-title">Transformation Stories</h3>
                <div class="stories-grid">
                    <div class="story-card" data-aos="fade-up" data-aos-delay="0">
                        <div class="story-header">
                            <div class="story-icon before">
                                <i class="fas fa-frown"></i>
                                <span>Before</span>
                            </div>
                            <div class="story-arrow">
                                <i class="fas fa-arrow-right"></i>
                            </div>
                            <div class="story-icon after">
                                <i class="fas fa-smile"></i>
                                <span>After</span>
                            </div>
                        </div>
                        <h4>Ravi's Family - From Homelessness to Housing</h4>
                        <div class="before-after">
                            <div class="before">
                                <strong>Before DRNF Support (2022)</strong>
                                <ul>
                                    <li>Living on streets for 3 years</li>
                                    <li>No stable income or employment</li>
                                    <li>Children not attending school</li>
                                    <li>No access to healthcare</li>
                                </ul>
                            </div>
                            <div class="after">
                                <strong>After DRNF Intervention (2024)</strong>
                                <ul>
                                    <li>Secured rental housing with DRNF assistance</li>
                                    <li>Stable employment through Ixora job program</li>
                                    <li>2 children now in school</li>
                                    <li>Regular health check-ups & nutrition support</li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <div class="story-card" data-aos="fade-up" data-aos-delay="100">
                        <div class="story-header">
                            <div class="story-icon before">
                                <i class="fas fa-frown"></i>
                                <span>Before</span>
                            </div>
                            <div class="story-arrow">
                                <i class="fas fa-arrow-right"></i>
                            </div>
                            <div class="story-icon after">
                                <i class="fas fa-smile"></i>
                                <span>After</span>
                            </div>
                        </div>
                        <h4>Priya's Journey - Education to Employment</h4>
                        <div class="before-after">
                            <div class="before">
                                <strong>Before DRNF Support (2020)</strong>
                                <ul>
                                    <li>Dropped out of 10th grade</li>
                                    <li>Financially struggling family</li>
                                    <li>No clear career path</li>
                                    <li>Low confidence and limited skills</li>
                                </ul>
                            </div>
                            <div class="after">
                                <strong>After DRNF Programs (2024)</strong>
                                <ul>
                                    <li>Completed high school with scholarship</li>
                                    <li>Enrolled in vocational training</li>
                                    <li>Employed with steady income</li>
                                    <li>Supporting family, mentoring younger students</li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <div class="story-card" data-aos="fade-up" data-aos-delay="200">
                        <div class="story-header">
                            <div class="story-icon before">
                                <i class="fas fa-frown"></i>
                                <span>Before</span>
                            </div>
                            <div class="story-arrow">
                                <i class="fas fa-arrow-right"></i>
                            </div>
                            <div class="story-icon after">
                                <i class="fas fa-smile"></i>
                                <span>After</span>
                            </div>
                        </div>
                        <h4>Meera's Family - Medical Crisis Averted</h4>
                        <div class="before-after">
                            <div class="before">
                                <strong>Before Emergency Support (2024)</strong>
                                <ul>
                                    <li>Father suffered severe heart attack</li>
                                    <li>No savings for medical treatment</li>
                                    <li>Family facing bankruptcy</li>
                                    <li>Children's education at risk</li>
                                </ul>
                            </div>
                            <div class="after">
                                <strong>After DRNF Emergency Fund (2024)</strong>
                                <ul>
                                    <li>Medical treatment successfully completed</li>
                                    <li>Father recovering and back to work</li>
                                    <li>Financial burden significantly reduced</li>
                                    <li>Children continuing education without stress</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Emergency Response Case Studies -->
            <div class="emergency-section" data-aos="fade-up" data-aos-delay="400">
                <h3 class="emergency-title">Rapid Emergency Response Cases</h3>
                <p class="emergency-subtitle">When families need help most, DRNF responds within 24-48 hours</p>

                <div class="emergency-cases">
                    <div class="emergency-case" data-aos="fade-up" data-aos-delay="0">
                        <div class="case-number">Case 001</div>
                        <h4><i class="fas fa-heartbeat"></i> Medical Emergency Response</h4>
                        <div class="case-timeline">
                            <div class="case-step">
                                <span class="step-time">Hour 0</span>
                                <p>Family contacts DRNF - child with appendicitis needs immediate surgery</p>
                            </div>
                            <div class="case-step">
                                <span class="step-time">Hour 2</span>
                                <p>Emergency fund approved, ₹40,000 released to hospital</p>
                            </div>
                            <div class="case-step">
                                <span class="step-time">Hour 6</span>
                                <p>Successful surgery completed, family meals arranged</p>
                            </div>
                            <div class="case-step">
                                <span class="step-time">Post Recovery</span>
                                <p>Follow-up support and additional ₹10,000 for medicines provided</p>
                            </div>
                        </div>
                        <div class="case-impact">Result: Child fully recovered, family avoided debt</div>
                    </div>

                    <div class="emergency-case" data-aos="fade-up" data-aos-delay="100">
                        <div class="case-number">Case 002</div>
                        <h4><i class="fas fa-home"></i> Housing Emergency Response</h4>
                        <div class="case-timeline">
                            <div class="case-step">
                                <span class="step-time">Day 1</span>
                                <p>Family loses home due to building demolition, no shelter</p>
                            </div>
                            <div class="case-step">
                                <span class="step-time">Day 2</span>
                                <p>Emergency lodging arranged, ₹3,000 advance for relocation</p>
                            </div>
                            <div class="case-step">
                                <span class="step-time">Week 1</span>
                                <p>Rental deposit paid, temporary housing secured for 3 months</p>
                            </div>
                            <div class="case-step">
                                <span class="step-time">Month 3</span>
                                <p>Permanent housing assistance and job placement support</p>
                            </div>
                        </div>
                        <div class="case-impact">Result: Family secured stable housing and income</div>
                    </div>

                    <div class="emergency-case" data-aos="fade-up" data-aos-delay="200">
                        <div class="case-number">Case 003</div>
                        <h4><i class="fas fa-graduation-cap"></i> Education Emergency Response</h4>
                        <div class="case-timeline">
                            <div class="case-step">
                                <span class="step-time">Situation</span>
                                <p>Student forced to drop out due to mother's unemployment</p>
                            </div>
                            <div class="case-step">
                                <span class="step-time">Day 1</span>
                                <p>DRNF scholarship approved, ₹5,000 for annual fees</p>
                            </div>
                            <div class="case-step">
                                <span class="step-time">Week 1</span>
                                <p>Mother enrolled in job training program, monthly stipend</p>
                            </div>
                            <div class="case-step">
                                <span class="step-time">6 Months</span>
                                <p>Mother employed, student continuing education, improved grades</p>
                            </div>
                        </div>
                        <div class="case-impact">Result: Education preserved and family economy strengthened</div>
                    </div>
                </div>
            </div>

            <!-- Partner Organizations & Testimonials -->
            <div class="partners-section" data-aos="fade-up" data-aos-delay="500">
                <h3 class="partners-title">Our Partners & Their Support</h3>

                <div class="partners-grid">
                    <div class="partner-card" data-aos="fade-up" data-aos-delay="0">
                        <div class="partner-logo">
                            <i class="fas fa-building"></i>
                            <span>Ixora Group</span>
                        </div>
                        <div class="partner-testimonial">
                            <blockquote>
                                "Ixora Group's support has been instrumental in our community programs. From job creation to emergency funding, they believe in sustainable impact."
                            </blockquote>
                            <p class="testimonial-author">- DRNF Leadership</p>
                        </div>
                    </div>

                    <div class="partner-card" data-aos="fade-up" data-aos-delay="100">
                        <div class="partner-logo">
                            <i class="fas fa-heart"></i>
                            <span>Abhi Sai Datta Trust</span>
                        </div>
                        <div class="partner-testimonial">
                            <blockquote>
                                "DRNF's educational workshops and meal support have transformed lives. Over 70 students have benefited directly."
                            </blockquote>
                            <p class="testimonial-author">- Trust Director</p>
                        </div>
                    </div>

                    <div class="partner-card" data-aos="fade-up" data-aos-delay="200">
                        <div class="partner-logo">
                            <i class="fas fa-toilet"></i>
                            <span>LooCafe Network</span>
                        </div>
                        <div class="partner-testimonial">
                            <blockquote>
                                "The Free Chai Counters through DRNF partnership serve 500+ cups daily. A lifeline for our homeless community."
                            </blockquote>
                            <p class="testimonial-author">- LooCafe Operations</p>
                        </div>
                    </div>

                    <div class="partner-card" data-aos="fade-up" data-aos-delay="300">
                        <div class="partner-logo">
                            <i class="fas fa-paw"></i>
                            <span>People for Animals</span>
                        </div>
                        <div class="partner-testimonial">
                            <blockquote>
                                "DRNF's animal welfare initiatives have funded rescue operations and provided veterinary care for dozens of animals."
                            </blockquote>
                            <p class="testimonial-author">- Animal Welfare Officer</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Urgent Needs Section -->
            <div class="urgent-needs-section" data-aos="fade-up" data-aos-delay="600">
                <h3 class="urgent-title"><i class="fas fa-bell"></i> Current Urgent Needs</h3>
                <p class="urgent-subtitle">Your help can make an immediate difference in these critical areas</p>

                <div class="needs-grid">
                    <div class="need-card critical" data-aos="fade-up" data-aos-delay="0">
                        <div class="need-badge">URGENT</div>
                        <h4><i class="fas fa-snowflake"></i> Winter Relief Fund</h4>
                        <p>With winter approaching, we urgently need support for blankets, warm clothing, and shelter for 300+ homeless individuals.</p>
                        <div class="need-details">
                            <span class="need-goal">Target: ₹2,00,000</span>
                            <div class="need-progress-bar">
                                <div class="need-progress-fill" style="width: 35%;"></div>
                            </div>
                            <span class="need-status">₹70,000 collected | 35% funded</span>
                        </div>
                        <a href="#donate" class="need-cta">Contribute Now</a>
                    </div>

                    <div class="need-card critical" data-aos="fade-up" data-aos-delay="100">
                        <div class="need-badge">URGENT</div>
                        <h4><i class="fas fa-heartbeat"></i> Medical Emergency Fund</h4>
                        <p>12 families currently face life-threatening health crises but cannot afford treatment. Emergency surgeries and medications needed.</p>
                        <div class="need-details">
                            <span class="need-goal">Target: ₹3,00,000</span>
                            <div class="need-progress-bar">
                                <div class="need-progress-fill" style="width: 28%;"></div>
                            </div>
                            <span class="need-status">₹84,000 collected | 28% funded</span>
                        </div>
                        <a href="#donate" class="need-cta">Contribute Now</a>
                    </div>

                    <div class="need-card high-priority" data-aos="fade-up" data-aos-delay="200">
                        <div class="need-badge">HIGH PRIORITY</div>
                        <h4><i class="fas fa-graduation-cap"></i> Education Scholarships</h4>
                        <p>25 brilliant students from underprivileged families are at risk of dropping out. They need school fees, books, and supplies.</p>
                        <div class="need-details">
                            <span class="need-goal">Target: ₹1,50,000</span>
                            <div class="need-progress-bar">
                                <div class="need-progress-fill" style="width: 52%;"></div>
                            </div>
                            <span class="need-status">₹78,000 collected | 52% funded</span>
                        </div>
                        <a href="#donate" class="need-cta">Contribute Now</a>
                    </div>

                    <div class="need-card high-priority" data-aos="fade-up" data-aos-delay="300">
                        <div class="need-badge">HIGH PRIORITY</div>
                        <h4><i class="fas fa-bowl-food"></i> Daily Meal Program</h4>
                        <p>Running our meal programs for 200 people daily costs ₹15,000/day. We're short by ₹5,000 daily to serve everyone.</p>
                        <div class="need-details">
                            <span class="need-goal">Monthly Goal: ₹1,50,000</span>
                            <div class="need-progress-bar">
                                <div class="need-progress-fill" style="width: 65%;"></div>
                            </div>
                            <span class="need-status">₹97,500 collected | 65% funded</span>
                        </div>
                        <a href="#donate" class="need-cta">Contribute Now</a>
                    </div>

                    <div class="need-card ongoing" data-aos="fade-up" data-aos-delay="400">
                        <div class="need-badge">ONGOING</div>
                        <h4><i class="fas fa-hands-helping"></i> Direct Family Assistance</h4>
                        <p>Monthly utility bills, rent, and emergency support for 80+ families living below poverty line.</p>
                        <div class="need-details">
                            <span class="need-goal">Monthly Need: ₹2,00,000</span>
                            <div class="need-progress-bar">
                                <div class="need-progress-fill" style="width: 45%;"></div>
                            </div>
                            <span class="need-status">₹90,000 collected | 45% funded</span>
                        </div>
                        <a href="#donate" class="need-cta">Contribute Now</a>
                    </div>

                    <div class="need-card ongoing" data-aos="fade-up" data-aos-delay="500">
                        <div class="need-badge">ONGOING</div>
                        <h4><i class="fas fa-tools"></i> Skill Development Programs</h4>
                        <p>Training materials and instructor costs for vocational skills programs. Each person trained gains employment capability.</p>
                        <div class="need-details">
                            <span class="need-goal">Quarterly Goal: ₹1,00,000</span>
                            <div class="need-progress-bar">
                                <div class="need-progress-fill" style="width: 60%;"></div>
                            </div>
                            <span class="need-status">₹60,000 collected | 60% funded</span>
                        </div>
                        <a href="#donate" class="need-cta">Contribute Now</a>
                    </div>
                </div>

                <div class="urgent-callout" data-aos="zoom-in" data-aos-delay="600">
                    <h4>Every contribution saves lives</h4>
                    <p>₹500 provides meals for a week | ₹2,000 sends a child to school | ₹5,000 provides emergency medical care | ₹10,000 saves a family from homelessness</p>
                    <a href="#donate" class="callout-cta">Make Your Impact Today</a>
                </div>
            </div>

            <div class="donation-gallery" data-aos="fade-up" data-aos-delay="200">
                <div class="gallery-item">
                    <img src="/images/initiatives/animal-welfare.png"
                         alt="DRNF and Ixora Group Blood Donation Drive 2024 - community health initiative in Hyderabad"
                         loading="lazy">
                    <div class="gallery-overlay">
                        <h4>Blood Donation Drive 2024</h4>
                        <p>Ixora Group's community health initiative - "Give Blood, Give Life"</p>
                    </div>
                </div>
                <div class="gallery-item">
                    <img src="/images/team/community-group-photo-2022.png"
                         alt="DRNF Ganesh Chaturthi Festival Celebration 2024 - cultural community event with families and workers"
                         loading="lazy">
                    <div class="gallery-overlay">
                        <h4>Ganesh Chaturthi 2024</h4>
                        <p>Cultural celebration bringing our community together</p>
                    </div>
                </div>
                <div class="gallery-item">
                    <img src="/images/team/ved-with-google-1.png"
                         alt="DRNF and Ixora Group employee engagement trip - team building and worker welfare program"
                         loading="lazy">
