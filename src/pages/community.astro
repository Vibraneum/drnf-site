---
import Layout from '../layouts/Layout.astro';

const pageTitle = 'Community Initiatives | Dr. Rabinder Nath Foundation';
const pageDescription = "DRNF's community initiatives include regular donation drives, sanitation and education workshops, environmental conservation, and animal welfare programs in Hyderabad.";
---

<Layout title={pageTitle} description={pageDescription} activePage="community">
  
<section class="page-hero">
        <div class="container">
            <h1 data-aos="fade-up">Community Initiatives</h1>
            <p data-aos="fade-up" data-aos-delay="200">Building sustainable impact through community support, education, and environmental care</p>
        </div>
    </section>

    <!-- Donations Section -->
    <section id="donations" class="section donations-section">
        <div class="container">
            <h2 class="section-title" data-aos="fade-up">Community Initiatives</h2>

            <!-- Community Work Overview -->
            <div class="community-overview" data-aos="fade-up" data-aos-delay="100">
                <div class="overview-content">
                    <h3>Ongoing Community Support</h3>
                    <p>We are actively interested in and continuously run various donation drives and community support initiatives. Our foundation believes in sustainable, impactful giving that creates lasting change in our community.</p>

                    <div class="initiative-stats">
                        <div class="stat-card">
                            <div class="stat-icon">
                                <i class="fas fa-heart"></i>
                            </div>
                            <h4>Regular Drives</h4>
                            <p>Continuous community support programs</p>
                        </div>

                        <div class="stat-card">
                            <div class="stat-icon">
                                <i class="fas fa-hands-helping"></i>
                            </div>
                            <h4>Sustainable Impact</h4>
                            <p>Focus on long-term community development</p>
                        </div>

                        <div class="stat-card">
                            <div class="stat-icon">
                                <i class="fas fa-users"></i>
                            </div>
                            <h4>Community Centered</h4>
                            <p>Direct engagement with local families</p>
                        </div>
                    </div>

                    <div class="subtle-note">
                        <p><small>Past initiatives have facilitated support worth approximately ₹5,00,000 through various community programs</small></p>
                    </div>
                </div>
            </div>

            <div class="donation-gallery" data-aos="fade-up" data-aos-delay="200">
                <div class="gallery-item">
                    <img src="/images/initiatives/animal-welfare.png"
                         alt="DRNF and Ixora Group Blood Donation Drive 2024 - community health initiative in Hyderabad"
                         loading="lazy">
                    <div class="gallery-overlay">
                        <h4>Blood Donation Drive 2024</h4>
                        <p>Ixora Group's community health initiative - "Give Blood, Give Life"</p>
                    </div>
                </div>
                <div class="gallery-item">
                    <img src="/images/team/community-group-photo-2022.png"
                         alt="DRNF Ganesh Chaturthi Festival Celebration 2024 - cultural community event with families and workers"
                         loading="lazy">
                    <div class="gallery-overlay">
                        <h4>Ganesh Chaturthi 2024</h4>
                        <p>Cultural celebration bringing our community together</p>
                    </div>
                </div>
                <div class="gallery-item">
                    <img src="/images/team/ved-with-google-1.png"
                         alt="DRNF and Ixora Group employee engagement trip - team building and worker welfare program"
                         loading="lazy">
                    <div class="gallery-overlay">
                        <h4>Employee Engagement</h4>
                        <p>Ixora Group team bonding - demonstrating commitment to worker welfare</p>
                    </div>
                </div>
                <div class="gallery-item">
                    <img src="/images/team/community-service-team.jpg"
                         alt="DRNF team members at community service event - volunteers serving the homeless and underprivileged"
                         loading="lazy">
                    <div class="gallery-overlay">
                        <h4>Our Team in Action</h4>
                        <p>DRNF team members serving the community with compassion</p>
                    </div>
                </div>
                <div class="gallery-item">
                    <img src="/images/team/ved-with-google-2.png"
                         alt="DRNF team gathering - volunteers and staff celebrating community impact"
                         loading="lazy">
                    <div class="gallery-overlay">
                        <h4>Team Gathering</h4>
                        <p>Our dedicated team of volunteers and staff</p>
                    </div>
                </div>
                <div class="gallery-item">
                    <img src="https://res.cloudinary.com/dhupieu4x/image/upload/v1762599310/drnf-assets/drnf-assets/rabinder_nath_1.6.jpg"
                         alt="DRNF team at Abhi Sai Datta Trust orphanage support program"
                         loading="lazy">
                    <div class="gallery-overlay">
                        <h4>Orphanage Support</h4>
                        <p>DRNF team at Abhi Sai Datta Trust after week-long pandemic support</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Workshops Section -->
    <section id="workshops" class="section">
        <div class="container">
            <h2 class="section-title" data-aos="fade-up">Sanitation & Education Workshops</h2>
            <div class="workshop-intro" data-aos="fade-up" data-aos-delay="100">
                <blockquote>
                    "Our objective was to foster our own community. The Abhi Sai Datta Trust was filled with energetic young men that related to us. Since I first went there in 2018, I fell in love with their cheer and wanted to do more for them, and support their family that they had created with each other."
                </blockquote>
            </div>

            <div class="workshop-content">
                <div class="workshop-text" data-aos="fade-right">
                    <p>Filled with confidence to make a difference in 70 students' lives at the Trust, supported by DRNF's past efforts of donation drives for over <strong>6 months</strong> worth of meals to the trust, weekly workshops began at the Trust along with educational support items provided, beginning from 2020.</p>

                    <div class="workshop-features">
                        <div class="feature-item">
                            <i class="fas fa-graduation-cap"></i>
                            <span>Educational Support</span>
                        </div>
                        <div class="feature-item">
                            <i class="fas fa-hands-wash"></i>
                            <span>Sanitation Training</span>
                        </div>
                        <div class="feature-item">
                            <i class="fas fa-users"></i>
                            <span>Community Building</span>
                        </div>
                    </div>
                </div>

                <div class="workshop-media" data-aos="fade-left">
                    <div class="video-container">
                        <video controls poster="https://res.cloudinary.com/dhupieu4x/image/upload/v1762599312/drnf-assets/drnf-assets/rabinder_nath_5.1.jpg">
                            <source src="/images/initiatives/WhatsApp_Video_2023-02-16_at_19.50.41.mp4" type="video/mp4">
                            Your browser does not support the video tag.
                        </video>
                        <p class="video-caption">Workshop sessions with students</p>
                    </div>
                    <div class="video-container">
                        <video controls poster="https://res.cloudinary.com/dhupieu4x/image/upload/v1762599313/drnf-assets/drnf-assets/rabinder_nath_5.5.jpg">
                            <source src="/images/initiatives/WhatsApp_Video_2023-02-16_at_19.50.38.mp4" type="video/mp4">
                            Your browser does not support the video tag.
                        </video>
                        <p class="video-caption">Student creating art depicting sanitation - one of our favorite moments!</p>
                    </div>
                </div>
            </div>

            <div class="workshop-gallery" data-aos="fade-up" data-aos-delay="300">
                <div class="gallery-grid">
                    <img src="https://res.cloudinary.com/dhupieu4x/image/upload/v1762599312/drnf-assets/drnf-assets/rabinder_nath_5.1.jpg" alt="Workshop Activity 1">
                    <img src="https://res.cloudinary.com/dhupieu4x/image/upload/v1762599313/drnf-assets/drnf-assets/rabinder_nath_5.5.jpg" alt="Workshop Activity 2">
                    <img src="https://res.cloudinary.com/dhupieu4x/image/upload/v1762599296/drnf-assets/drnf-assets/Untitled_4.jpg" alt="Community Group Photo">
                </div>
                <p class="gallery-caption">Our community through DRNF—2022. Featuring childhood toys and some of our best teammates supporting our collective mission as a foundation.</p>
            </div>
        </div>
    </section>

    <!-- Environment Section -->
    <section id="environment" class="section environment-section">
        <div class="container">
            <h2 class="section-title" data-aos="fade-up">Environmental Initiatives</h2>
            <p class="section-subtitle" data-aos="fade-up" data-aos-delay="100">
                We're dedicated to causes such as animals, environment, and sanitation.
            </p>

            <!-- Tree Plantation -->
            <div class="environmental-activity" data-aos="fade-up" data-aos-delay="200">
                <div class="activity-content">
                    <div class="activity-text">
                        <h3><i class="fas fa-tree"></i> Tree Plantation Drives</h3>
                        <p>Regular tree plantation drives around the city, including our initiative around ITC Hotel in Hyderabad with members of the DRNF Support Team and Ixora Corporate Services.</p>
                    </div>
                    <div class="activity-image">
                        <img src="https://res.cloudinary.com/dhupieu4x/image/upload/v1762599315/drnf-assets/drnf-assets/rabinder_nath_drive.jpg" alt="Tree Plantation Drive">
                    </div>
                </div>
            </div>

            <!-- Animal Welfare -->
            <div class="animal-welfare" data-aos="fade-up" data-aos-delay="300">
                <h3><i class="fas fa-paw"></i> Animal Welfare</h3>
                <div class="animal-content">
                    <div class="animal-text">
                        <p>We support animal support organizations, such as People for Animals and individual animal rescue workers, including Pridhvi for animal rescue drives.</p>

                        <div class="animal-story">
                            <h4>Google's Story</h4>
                            <p>"My dog Google is a rescue dog himself, abandoned at the GHMC Dog Park where a LooCafe operates. A supervisor and a visitor of the park both took him home and abandoned him again. Google looked like a battered street dog that was over-friendly, confused for aggressiveness to park visitors, and was left to the streets until Google was brought home finally where he's currently living healthily for the last 4 years with Ved."</p>
                        </div>

                        <a href="https://www.facebook.com/108701563936406/photos/a.493495125457046/626222398850984/?type=3" target="_blank" class="animal-link">
                            <i class="fab fa-facebook"></i>
                            <span>Citizens for Animals - Pridhvi's Story</span>
                        </a>
                    </div>

                    <div class="animal-images">
                        <div class="animal-image-grid">
                            <img src="https://res.cloudinary.com/dhupieu4x/image/upload/v1762599297/drnf-assets/drnf-assets/Untitled_5.jpg" alt="Animal Welfare 1">
                            <div class="small-images">
                                <img src="https://res.cloudinary.com/dhupieu4x/image/upload/v1762599298/drnf-assets/drnf-assets/Untitled_6.jpg" alt="Ved with Google 1">
                                <img src="https://res.cloudinary.com/dhupieu4x/image/upload/v1762599300/drnf-assets/drnf-assets/Untitled_7.jpg" alt="Ved with Google 2">
                            </div>
                        </div>
                        <p class="image-caption">Ved after a year of developing an understanding with Google at the Dog Park</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Social Share Section -->
    <section class="section">
        <div class="container">
            <div class="social-share-section" data-aos="fade-up">
                <h3>Share Our Mission</h3>
                <p>Help us spread the word about our community support and educational programs</p>
                <div class="share-buttons">
                    <a href="https://www.facebook.com/sharer/sharer.php?u=" class="share-btn facebook" target="_blank" rel="noopener noreferrer" data-share="facebook">
                        <i class="fab fa-facebook-f"></i>
                        <span>Facebook</span>
                    </a>
                    <a href="https://twitter.com/intent/tweet?url=" class="share-btn twitter" target="_blank" rel="noopener noreferrer" data-share="twitter">
                        <i class="fab fa-x-twitter"></i>
                        <span>Twitter</span>
                    </a>
                    <a href="https://www.linkedin.com/sharing/share-offsite/?url=" class="share-btn linkedin" target="_blank" rel="noopener noreferrer" data-share="linkedin">
                        <i class="fab fa-linkedin-in"></i>
                        <span>LinkedIn</span>
                    </a>
                    <a href="https://wa.me/?text=Check%20out%20DRNF's%20Community%20Support%20Programs%20-%20" class="share-btn whatsapp" target="_blank" rel="noopener noreferrer" data-share="whatsapp">
                        <i class="fab fa-whatsapp"></i>
                        <span>WhatsApp</span>
                    </a>
                </div>
            </div>
        </div>
    </section>
  
  <!-- Back to Top Button -->
  <button class="back-to-top" id="backToTop" aria-label="Back to top">
    <i class="fas fa-arrow-up"></i>
  </button>
</Layout>

<style>
  .back-to-top {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    width: 50px;
    height: 50px;
    background: linear-gradient(135deg, var(--primary-color) 0%, var(--accent-color) 100%);
    color: white;
    border: none;
    border-radius: 50%;
    cursor: pointer;
    display: none;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    box-shadow: 0 4px 15px rgba(0,0,0,0.2);
    z-index: 1000;
    transition: all 0.3s ease;
  }
  
  .back-to-top:hover {
    transform: translateY(-5px);
    box-shadow: 0 6px 20px rgba(0,0,0,0.3);
  }
  
  @media (max-width: 768px) {
    .back-to-top {
      bottom: 1.5rem;
      right: 1.5rem;
      width: 45px;
      height: 45px;
    }
  }
</style>

<script>
  // Back to top button functionality
  if (typeof document !== 'undefined') {
    const backToTopBtn = document.getElementById('backToTop');
    if (backToTopBtn) {
      window.addEventListener('scroll', () => {
        if (window.pageYOffset > 300) {
          backToTopBtn.style.display = 'flex';
        } else {
          backToTopBtn.style.display = 'none';
        }
      });
      
      backToTopBtn.addEventListener('click', () => {
        window.scrollTo({
          top: 0,
          behavior: 'smooth'
        });
      });
    }
  }
</script>

<script>
  // Current year in footer
  if (typeof document !== 'undefined') {
    const yearElement = document.getElementById('current-year');
    if (yearElement) {
      yearElement.textContent = new Date().getFullYear();
    }
  }
</script>
