---
import Layout from '../layouts/Layout.astro';

const pageTitle = "About Us - Dr. Rabinder Nath Foundation | Our Story & Vision";
const pageDescription = "Learn about the vision behind DRNF, founded by Abhishek Nath to honor his father Dr. Rabinder Nath's legacy of community service. Discover how we partner with LooCafe to maximize social impact across Hyderabad.";
---

<Layout title={pageTitle} description={pageDescription} activePage="about">
  
  <!-- Page Hero Section -->
    <section class="page-hero">
        <div class="container">
            <h1 data-aos="fade-up">Our Story</h1>
            <p data-aos="fade-up" data-aos-delay="200">A vision of compassion, a legacy of service, and a commitment to community</p>
        </div>
    </section>

    <!-- Founder's Vision Section -->
    <section class="section about-section">
        <div class="container">
            <div class="about-content">
                <div class="about-text" data-aos="fade-right">
                    <h2 class="section-title">Founder's Vision</h2>
                    <p class="about-description">
                        The Dr. Rabinder Nath Foundation was founded in 2016 by Abhishek Nath, driven by a deeply personal mission to honor the memory and continue the legacy of his father, the late Dr. Rabinder Nath.
                    </p>
                    <p>
                        Growing up witnessing his father's unwavering commitment to community service, Abhishek understood that true impact comes not just from good intentions, but from creating sustainable systems that serve people with dignity and compassion.
                    </p>
                    <p>
                        "My father believed that no act of kindness, however small, is ever wasted. He spent his life serving others, and through this foundation, we ensure that his spirit of giving continues to touch lives every single day."
                    </p>
                    <div class="about-highlights">
                        <div class="highlight-item">
                            <i class="fas fa-heart"></i>
                            <span>Family Legacy</span>
                        </div>
                        <div class="highlight-item">
                            <i class="fas fa-hands-helping"></i>
                            <span>Sustainable Impact</span>
                        </div>
                        <div class="highlight-item">
                            <i class="fas fa-users"></i>
                            <span>Community First</span>
                        </div>
                    </div>
                </div>
                <div class="about-media" data-aos="fade-left">
                    <img src="https://res.cloudinary.com/dhupieu4x/image/upload/v1762599308/drnf-assets/drnf-assets/rabinder_nath2.1.jpg" alt="Dr. Rabinder Nath" class="about-image">
                </div>
            </div>
        </div>
    </section>
  
  <!-- Back to Top Button -->
  <button class="back-to-top" id="backToTop" aria-label="Back to top">
    <i class="fas fa-arrow-up"></i>
  </button>
</Layout>

<style>
  .back-to-top {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    width: 50px;
    height: 50px;
    background: linear-gradient(135deg, var(--primary-color) 0%, var(--accent-color) 100%);
    color: white;
    border: none;
    border-radius: 50%;
    cursor: pointer;
    display: none;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    box-shadow: 0 4px 15px rgba(0,0,0,0.2);
    z-index: 1000;
    transition: all 0.3s ease;
  }
  
  .back-to-top:hover {
    transform: translateY(-5px);
    box-shadow: 0 6px 20px rgba(0,0,0,0.3);
  }
  
  @media (max-width: 768px) {
    .back-to-top {
      bottom: 1.5rem;
      right: 1.5rem;
      width: 45px;
      height: 45px;
    }
  }
</style>

<script>
  // Back to top button functionality
  if (typeof document !== 'undefined') {
    const backToTopBtn = document.getElementById('backToTop');
    if (backToTopBtn) {
      window.addEventListener('scroll', () => {
        if (window.pageYOffset > 300) {
          backToTopBtn.style.display = 'flex';
        } else {
          backToTopBtn.style.display = 'none';
        }
      });
      
      backToTopBtn.addEventListener('click', () => {
        window.scrollTo({
          top: 0,
          behavior: 'smooth'
        });
      });
    }
  }
</script>
