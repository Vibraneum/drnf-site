---
import Layout from '../../layouts/Layout.astro';

const pageTitle = "About Us - Dr. Rabinder Nath Foundation | Our Story & Vision";
const pageDescription = "Learn about the vision behind DRNF, founded by Abhishek Nath to honor his father Dr. Rabinder Nath's legacy of community service. Discover how we partner with LooCafe to maximize social impact across Hyderabad.";
---

<Layout title={pageTitle} description={pageDescription}>
    <!-- Main Enhanced Navigation -->
    <nav class="enhanced-nav" id="enhancedNav">
        <div class="nav-container-enhanced">
            <!-- Logo & Brand -->
            <a href="index.html" class="nav-logo-enhanced">
                <img src="https://res.cloudinary.com/dhupieu4x/image/upload/v1762599287/drnf-assets/drnf-assets/DRNF_logo.jpg" alt="Dr. Rabinder Nath Foundation Logo" class="logo-img">
                <div class="nav-brand-text">
                    <h1 class="brand-title">Dr. Rabinder Nath Foundation</h1>
                    <p class="brand-tagline">Serving with Compassion</p>
                </div>
            </a>

            <!-- Desktop Navigation Links -->
            <ul class="nav-links-enhanced">
                <li><a href="index.html" class="nav-link-enhanced">Home</a></li>

                <!-- About Dropdown -->
                <li>
                    <div class="nav-link-enhanced nav-dropdown-trigger active" data-menu="about-mega-menu">
                        <span>About</span>
                        <svg class="chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                        </svg>
                    </div>
                </li>

                <li><a href="book.html" class="nav-link-enhanced">Heritage Book</a></li>

                <!-- Programs Dropdown -->
                <li>
                    <div class="nav-link-enhanced nav-dropdown-trigger" data-menu="programs-mega-menu">
                        <span>Our Programs</span>
                        <svg class="chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                        </svg>
                    </div>
                </li>

                <li><a href="contact.html" class="nav-link-enhanced">Contact</a></li>
                <li><a href="faq.html" class="nav-link-enhanced">FAQ</a></li>
            </ul>

            <!-- Navigation Actions -->
            <div class="nav-actions-enhanced">
                <a href="about.html" class="nav-cta-enhanced">Our Story</a>
                <button class="mobile-menu-toggle" aria-label="Toggle mobile menu">
                    <span></span>
                    <span></span>
                    <span></span>
                </button>
            </div>
        </div>

        <!-- About Mega Menu -->
        <div class="mega-menu" id="about-mega-menu">
            <div class="mega-menu-container">
                <div class="mega-menu-content">
                    <!-- Left Side Card -->
                    <div class="mega-menu-card">
                        <img src="https://res.cloudinary.com/dhupieu4x/image/upload/v1762599308/drnf-assets/drnf-assets/rabinder_nath2.1.jpg" alt="About Us">
                        <h3>About Us</h3>
                        <p>Learn about our story, mission, and the legacy of Dr. Rabinder Nath.</p>
                        <div class="arrow-circle">
                            <i class="fas fa-arrow-right"></i>
                        </div>
                    </div>

                    <!-- Right Side Grid -->
                    <div class="mega-menu-grid">
                        <div class="mega-menu-header">
                            <h3>Discover Our Foundation</h3>
                            <p>Learn more about our mission, values, and the legacy we continue.</p>
                        </div>

                        <div class="mega-menu-columns">
                            <!-- Column 1 -->
                            <div>
                                <a href="about.html" class="mega-menu-link">
                                    <i class="fas fa-book-open mega-menu-icon"></i>
                                    <span class="mega-menu-text">Our Story</span>
                                </a>
                                <a href="dr-rabinder-nath.html" class="mega-menu-link">
                                    <i class="fas fa-user-md mega-menu-icon"></i>
                                    <span class="mega-menu-text">Dr. Rabinder Nath</span>
                                </a>
                                <a href="book.html" class="mega-menu-link">
                                    <i class="fas fa-book mega-menu-icon"></i>
                                    <span class="mega-menu-text">Heritage Book</span>
                                </a>
                                <a href="about.html#team" class="mega-menu-link">
                                    <i class="fas fa-users mega-menu-icon"></i>
                                    <span class="mega-menu-text">Our Team</span>
                                </a>
                            </div>

                            <!-- Column 2 -->
                            <div>
                                <a href="about.html#mission" class="mega-menu-link">
                                    <i class="fas fa-bullseye mega-menu-icon"></i>
                                    <span class="mega-menu-text">Vision & Mission</span>
                                </a>
                                <a href="about.html#impact" class="mega-menu-link">
                                    <i class="fas fa-trophy mega-menu-icon"></i>
                                    <span class="mega-menu-text">Impact & Stats</span>
                                </a>
                                <a href="about.html#values" class="mega-menu-link">
                                    <i class="fas fa-star mega-menu-icon"></i>
                                    <span class="mega-menu-text">Our Values</span>
                                </a>
                                <a href="contact.html" class="mega-menu-link">
                                    <i class="fas fa-envelope mega-menu-icon"></i>
                                    <span class="mega-menu-text">Contact Us</span>
                                </a>
                            </div>
