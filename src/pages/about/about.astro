            <!-- Heritage Book -->
            <div class="mobile-menu-item">
                <a href="book.html" class="mobile-menu-link">Heritage Book</a>
            </div>

            <!-- Our Programs with Submenu -->
            <div class="mobile-menu-item">
                <a href="#" class="mobile-menu-link" data-submenu="programs">
                    <span>Our Programs</span>
                    <svg class="chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                    </svg>
                </a>
                <div class="mobile-submenu">
                    <a href="chai-counters.html" class="mobile-submenu-link">
                        <i class="fas fa-coffee"></i>
                        <span>Free Chai Counters</span>
                    </a>
                    <a href="community.html" class="mobile-submenu-link">
                        <i class="fas fa-hands-helping"></i>
                        <span>Community Support</span>
                    </a>
                    <a href="community.html#workshops" class="mobile-submenu-link">
                        <i class="fas fa-graduation-cap"></i>
                        <span>Education Workshops</span>
                    </a>
                    <a href="community.html#environment" class="mobile-submenu-link">
                        <i class="fas fa-leaf"></i>
                        <span>Environmental Care</span>
                    </a>
                    <a href="community.html#animal-welfare" class="mobile-submenu-link">
                        <i class="fas fa-paw"></i>
                        <span>Animal Welfare</span>
                    </a>
                    <a href="contact.html" class="mobile-submenu-link">
                        <i class="fas fa-heart"></i>
                        <span>Get in Touch</span>
                    </a>
                </div>
            </div>

            <!-- Contact -->
            <div class="mobile-menu-item">
                <a href="contact.html" class="mobile-menu-link">Contact</a>
            </div>

            <!-- FAQ -->
            <div class="mobile-menu-item">
                <a href="faq.html" class="mobile-menu-link">FAQ</a>
            </div>

            <!-- Mobile CTA -->
            <div class="mobile-menu-cta">
                <a href="about.html" class="nav-cta-enhanced">Our Story</a>
