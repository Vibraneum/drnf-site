        </div>

        <!-- Programs Mega Menu -->
        <div class="mega-menu" id="programs-mega-menu">
            <div class="mega-menu-container">
                <div class="mega-menu-content">
                    <!-- Left Side Card -->
                    <div class="mega-menu-card">
                        <img src="images/chai_counter.jpg" alt="Our Programs">
                        <h3>Our Programs</h3>
                        <p>Explore our community service initiatives and programs making a difference.</p>
