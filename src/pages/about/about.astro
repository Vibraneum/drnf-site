                    <h1 class="brand-title">DRNF</h1>
                </div>
            </a>
            <button class="mobile-menu-close" aria-label="Close mobile menu">
                <i class="fas fa-times"></i>
            </button>
        </div>

        <div class="mobile-menu-body">
            <!-- Home -->
            <div class="mobile-menu-item">
                <a href="index.html" class="mobile-menu-link">Home</a>
            </div>

            <!-- About with Submenu -->
            <div class="mobile-menu-item">
                <a href="#" class="mobile-menu-link" data-submenu="about">
                    <span>About</span>
                    <svg class="chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                    </svg>
                </a>
                <div class="mobile-submenu">
                    <a href="about.html" class="mobile-submenu-link">
                        <i class="fas fa-book-open"></i>
                        <span>Our Story</span>
                    </a>
                    <a href="dr-rabinder-nath.html" class="mobile-submenu-link">
                        <i class="fas fa-user-md"></i>
                        <span>Dr. Rabinder Nath</span>
                    </a>
                    <a href="book.html" class="mobile-submenu-link">
                        <i class="fas fa-book"></i>
                        <span>Heritage Book</span>
                    </a>
                    <a href="about.html#team" class="mobile-submenu-link">
                        <i class="fas fa-users"></i>
                        <span>Our Team</span>
                    </a>
                    <a href="about.html#mission" class="mobile-submenu-link">
                        <i class="fas fa-bullseye"></i>
                        <span>Vision & Mission</span>
                    </a>
                    <a href="about.html#impact" class="mobile-submenu-link">
                        <i class="fas fa-trophy"></i>
                        <span>Impact & Stats</span>
                    </a>
                    <a href="about.html#values" class="mobile-submenu-link">
                        <i class="fas fa-star"></i>
                        <span>Our Values</span>
                    </a>
                </div>
