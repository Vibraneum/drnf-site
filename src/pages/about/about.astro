                            <i class="fas fa-arrow-right"></i>
                        </div>
                    </div>

                    <!-- Right Side Grid -->
                    <div class="mega-menu-grid">
                        <div class="mega-menu-header">
                            <h3>Community Service Programs</h3>
                            <p>Making a difference through dedicated community initiatives.</p>
                        </div>

                        <div class="mega-menu-columns">
                            <!-- Column 1 -->
                            <div>
                                <a href="chai-counters.html" class="mega-menu-link">
                                    <i class="fas fa-coffee mega-menu-icon"></i>
                                    <span class="mega-menu-text">Free Chai Counters</span>
                                </a>
                                <a href="community.html" class="mega-menu-link">
                                    <i class="fas fa-hands-helping mega-menu-icon"></i>
                                    <span class="mega-menu-text">Community Support</span>
                                </a>
                                <a href="community.html#workshops" class="mega-menu-link">
                                    <i class="fas fa-graduation-cap mega-menu-icon"></i>
                                    <span class="mega-menu-text">Education Workshops</span>
                                </a>
                            </div>

                            <!-- Column 2 -->
                            <div>
                                <a href="community.html#environment" class="mega-menu-link">
                                    <i class="fas fa-leaf mega-menu-icon"></i>
