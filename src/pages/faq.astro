---
import Layout from '../layouts/Layout.astro';

const pageTitle = 'FAQ - Dr. Rabinder Nath Foundation | Common Questions About Our Work';
const pageDescription = "Frequently asked questions about DRNF's free chai counters, volunteer opportunities, donation process, and community programs in Hyderabad.";
---

<Layout title={pageTitle} description={pageDescription} activePage="faq">
  
<section class="page-hero">
        <div class="container">
            <h1 data-aos="fade-up">Frequently Asked Questions</h1>
            <p data-aos="fade-up" data-aos-delay="200">Everything you need to know about DRNF and our community programs</p>
        </div>
    </section>

    <!-- FAQ Section -->
    <section class="section faq-section">
        <div class="container">
            <div class="faq-container">

                <!-- About DRNF -->
                <div class="faq-category" data-aos="fade-up">
                    <h2><i class="fas fa-info-circle"></i> About DRNF</h2>

                    <div class="faq-item">
                        <div class="faq-question">
                            <h3>What is Dr. Rabinder Nath Foundation (DRNF)?</h3>
                            <i class="fas fa-chevron-down"></i>
                        </div>
                        <div class="faq-answer">
                            <p>Dr. Rabinder Nath Foundation (DRNF) is a community service organization based in Hyderabad, India. Founded in 2020, we are dedicated to serving the community through multiple initiatives including free chai counters, sanitation workshops, environmental conservation, and community support programs. We honor the legacy of Dr. Rabinder Nath through compassionate service.</p>
                        </div>
                    </div>

                    <div class="faq-item">
                        <div class="faq-question">
                            <h3>When was DRNF established?</h3>
                            <i class="fas fa-chevron-down"></i>
                        </div>
                        <div class="faq-answer">
                            <p>DRNF was founded in 2020 with a mission to serve the community with compassion and care, continuing the legacy of Dr. Rabinder Nath.</p>
                        </div>
                    </div>

                    <div class="faq-item">
                        <div class="faq-question">
                            <h3>What areas does DRNF serve?</h3>
                            <i class="fas fa-chevron-down"></i>
                        </div>
                        <div class="faq-answer">
                            <p>We primarily serve Hyderabad, Telangana, India. Our free chai counters and community programs are strategically located across the city to maximize impact and reach those who need it most.</p>
                        </div>
                    </div>
                </div>

                <!-- Free Chai Counters -->
                <div class="faq-category" data-aos="fade-up">
                    <h2><i class="fas fa-coffee"></i> Free Chai Counters</h2>

                    <div class="faq-item">
                        <div class="faq-question">
                            <h3>Where are the free chai counters located in Hyderabad?</h3>
                            <i class="fas fa-chevron-down"></i>
                        </div>
                        <div class="faq-answer">
                            <p>We currently operate 2 active free chai counters in Hyderabad through our partnership with LooCafe. The counters are strategically placed to serve the community effectively. For specific locations, please contact us via WhatsApp.</p>
                        </div>
                    </div>

                    <div class="faq-item">
                        <div class="faq-question">
                            <h3>How many cups of chai have been served?</h3>
                            <i class="fas fa-chevron-down"></i>
                        </div>
                        <div class="faq-answer">
                            <p>We've proudly served over 1,16,800 cups of tea to the community! This number continues to grow as we expand our reach and serve more people every day.</p>
                        </div>
                    </div>

                    <div class="faq-item">
                        <div class="faq-question">
                            <h3>How does DRNF's partnership with LooCafe work?</h3>
                            <i class="fas fa-chevron-down"></i>
                        </div>
                        <div class="faq-answer">
                            <p>Our free chai counters are implemented through our strategic partnership with <a href="https://loocafe.com" target="_blank" rel="noopener">LooCafe.com</a>, leveraging their extensive network of 270+ locations across Hyderabad. We successfully piloted this program across 30 LooCafes in 2022-2023 and plan to expand further across India.</p>
                        </div>
                    </div>

                    <div class="faq-item">
                        <div class="faq-question">
                            <h3>Who can access the free chai counters?</h3>
                            <i class="fas fa-chevron-down"></i>
                        </div>
                        <div class="faq-answer">
                            <p>The free chai counters are open to everyone in the community, with a special focus on serving those in need. Our mission is to provide warmth, comfort, and a moment of respite to all.</p>
                        </div>
                    </div>

                    <div class="faq-item">
                        <div class="faq-question">
                            <h3>How many jobs have been created through this initiative?</h3>
                            <i class="fas fa-chevron-down"></i>
                        </div>
                        <div class="faq-answer">
                            <p>Our free chai counter initiative has created 70+ jobs, providing sustainable employment opportunities to members of the community while serving a greater purpose.</p>
                        </div>
                    </div>
                </div>

                <!-- Volunteering -->
                <div class="faq-category" data-aos="fade-up">
                    <h2><i class="fas fa-hands-helping"></i> Volunteering & Support</h2>

                    <div class="faq-item">
                        <div class="faq-question">
                            <h3>How can I volunteer with DRNF?</h3>
                            <i class="fas fa-chevron-down"></i>
                        </div>
                        <div class="faq-answer">
                            <p>We welcome volunteers! You can join us by:</p>
                            <ul>
                                <li>Contacting us via <a href="https://wa.me/919966906781" target="_blank" rel="noopener">WhatsApp</a></li>
                                <li>Emailing us at <a href="mailto:info@drnf.org">info@drnf.org</a></li>
                                <li>Visiting our <a href="/contact">Contact page</a> for more information</li>
                            </ul>
                            <p>Volunteer opportunities include free chai counter operations, community support programs, educational workshops, environmental initiatives, and animal welfare activities.</p>
                        </div>
                    </div>

                    <div class="faq-item">
                        <div class="faq-question">
                            <h3>What volunteer opportunities are available?</h3>
                            <i class="fas fa-chevron-down"></i>
                        </div>
                        <div class="faq-answer">
                            <p>We offer diverse volunteering opportunities:</p>
                            <ul>
                                <li><strong>Free Chai Counter Operations:</strong> Help serve tea and interact with the community</li>
                                <li><strong>Community Support Programs:</strong> Assist with donation drives and community outreach</li>
                                <li><strong>Educational Workshops:</strong> Support sanitation and hygiene education</li>
                                <li><strong>Environmental Initiatives:</strong> Join tree plantation and conservation drives</li>
                                <li><strong>Animal Welfare:</strong> Participate in rescue and care activities</li>
                            </ul>
                        </div>
                    </div>

                    <div class="faq-item">
                        <div class="faq-question">
                            <h3>Can businesses or organizations partner with DRNF?</h3>
                            <i class="fas fa-chevron-down"></i>
                        </div>
                        <div class="faq-answer">
                            <p>Absolutely! We welcome partnerships with businesses and organizations. We currently partner with <a href="https://ixoragroup.com" target="_blank" rel="noopener">Ixora Group</a>, <a href="https://loocafe.com" target="_blank" rel="noopener">LooCafe</a>, and Kadak Chai. Contact us to discuss partnership opportunities.</p>
                        </div>
                    </div>
                </div>

                <!-- Programs & Initiatives -->
                <div class="faq-category" data-aos="fade-up">
                    <h2><i class="fas fa-heart"></i> Programs & Initiatives</h2>

                    <div class="faq-item">
                        <div class="faq-question">
                            <h3>What other programs does DRNF run besides free chai counters?</h3>
                            <i class="fas fa-chevron-down"></i>
                        </div>
                        <div class="faq-answer">
                            <p>Beyond free chai counters, DRNF runs several impactful programs:</p>
                            <ul>
                                <li><strong>Community Work:</strong> Support programs for those in need</li>
                                <li><strong>Sanitation Workshops:</strong> Education on hygiene and sanitation practices</li>
                                <li><strong>Environmental Conservation:</strong> Tree plantation and cleanup drives</li>
                                <li><strong>Animal Welfare:</strong> Rescue and care for stray animals</li>
                                <li><strong>Educational Workshops:</strong> Skill development and awareness programs</li>
                            </ul>
                        </div>
                    </div>

                    <div class="faq-item">
                        <div class="faq-question">
                            <h3>Does DRNF work with orphanages or other NGOs?</h3>
                            <i class="fas fa-chevron-down"></i>
                        </div>
                        <div class="faq-answer">
                            <p>Yes! We actively collaborate with other organizations and have supported orphanages like Abhi Sai Datta Trust, especially during the pandemic. We believe in collective impact through partnerships.</p>
                        </div>
                    </div>

                    <div class="faq-item">
                        <div class="faq-question">
                            <h3>Are there plans to expand DRNF's programs?</h3>
                            <i class="fas fa-chevron-down"></i>
                        </div>
                        <div class="faq-answer">
                            <p>Yes! We plan to expand our Free Chai Counter program across LooCafe's network of 270+ locations in Hyderabad and eventually across India. We're also continuously developing new initiatives to serve the community better.</p>
                        </div>
                    </div>
                </div>

                <!-- Funding & Operations -->
                <div class="faq-category" data-aos="fade-up">
                    <h2><i class="fas fa-rupee-sign"></i> Funding & Operations</h2>

                    <div class="faq-item">
                        <div class="faq-question">
                            <h3>How is DRNF funded?</h3>
                            <i class="fas fa-chevron-down"></i>
                        </div>
                        <div class="faq-answer">
                            <p>DRNF operates on a self-sustained model with support from strategic partners including <a href="https://ixoragroup.com" target="_blank" rel="noopener">Ixora Group</a>, <a href="https://loocafe.com" target="_blank" rel="noopener">LooCafe</a>, and Kadak Chai partnership. This sustainable approach allows us to focus on long-term community impact.</p>
                        </div>
                    </div>

                    <div class="faq-item">
                        <div class="faq-question">
                            <h3>Is DRNF a registered nonprofit organization?</h3>
                            <i class="fas fa-chevron-down"></i>
                        </div>
                        <div class="faq-answer">
                            <p>Yes, Dr. Rabinder Nath Foundation is a registered nonprofit organization (NGO) based in Hyderabad, committed to transparent and accountable community service.</p>
                        </div>
                    </div>

                    <div class="faq-item">
                        <div class="faq-question">
                            <h3>Where is DRNF's office located?</h3>
                            <i class="fas fa-chevron-down"></i>
                        </div>
                        <div class="faq-answer">
                            <p>Our office is located at:<br>
                            <strong><a href="https://ixoragroup.com" target="_blank" rel="noopener">Ixora Corporate Services Pvt Ltd</a></strong><br>
                            Door No: 8, 2-293/82/J/A/101<br>
                            Journalist Colony, Jubilee Hills<br>
                            Hyderabad, Telangana 500033<br>
                            <a href="https://maps.google.com/?q=17.4239,78.4738" target="_blank">View on Google Maps</a></p>
                        </div>
                    </div>
                </div>

                <!-- Contact & Communication -->
                <div class="faq-category" data-aos="fade-up">
                    <h2><i class="fas fa-envelope"></i> Contact & Communication</h2>

                    <div class="faq-item">
                        <div class="faq-question">
                            <h3>How can I contact DRNF?</h3>
                            <i class="fas fa-chevron-down"></i>
                        </div>
                        <div class="faq-answer">
                            <p>You can reach us through:</p>
                            <ul>
                                <li><strong>WhatsApp:</strong> <a href="https://wa.me/919966906781" target="_blank" rel="noopener">Message Us</a></li>
                                <li><strong>Email:</strong> <a href="mailto:info@drnf.org">info@drnf.org</a></li>
                                <li><strong>Facebook:</strong> <a href="https://www.facebook.com/DrRabinderNathFoundation/" target="_blank">@DrRabinderNathFoundation</a></li>
                                <li><strong>LinkedIn:</strong> <a href="https://www.linkedin.com/company/dr-rabinder-nath-foundation/" target="_blank">Dr. Rabinder Nath Foundation</a></li>
                                <li><strong>Contact Page:</strong> <a href="/contact">Visit our Contact Page</a></li>
                            </ul>
                        </div>
                    </div>

                    <div class="faq-item">
                        <div class="faq-question">
                            <h3>How quickly can I expect a response?</h3>
                        <i class="fas fa-chevron-down"></i>
                        </div>
                        <div class="faq-answer">
                            <p>We strive to respond to all inquiries within 24-48 hours. For urgent matters, WhatsApp is the fastest way to reach us.</p>
                        </div>
                    </div>

                    <div class="faq-item">
                        <div class="faq-question">
                            <h3>Can I visit the free chai counters in person?</h3>
                            <i class="fas fa-chevron-down"></i>
                        </div>
                        <div class="faq-answer">
                            <p>Yes! Our chai counters are open to everyone. Contact us via WhatsApp for current locations and operating hours.</p>
                        </div>
                    </div>
                </div>

            </div>

            <!-- CTA Section -->
            <div class="faq-cta" data-aos="fade-up">
                <h3>Still have questions?</h3>
                <p>We're here to help! Reach out to us and we'll get back to you as soon as possible.</p>
                <div class="cta-buttons">
                    <a href="https://wa.me/919966906781" target="_blank" rel="noopener" class="btn btn-primary">
                        <i class="fab fa-whatsapp"></i> WhatsApp Us
                    </a>
                    <a href="/contact" class="btn btn-secondary">
                        <i class="fas fa-envelope"></i> Contact Page
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- Social Share Section -->
    <section class="section">
        <div class="container">
            <div class="social-share-section" data-aos="fade-up">
                <h3>Share Our Mission</h3>
                <p>Help us reach more people with answers about DRNF's work</p>
                <div class="share-buttons">
                    <a href="https://www.facebook.com/sharer/sharer.php?u=" class="share-btn facebook" target="_blank" rel="noopener noreferrer" data-share="facebook">
                        <i class="fab fa-facebook-f"></i>
                        <span>Facebook</span>
                    </a>
                    <a href="https://twitter.com/intent/tweet?url=" class="share-btn twitter" target="_blank" rel="noopener noreferrer" data-share="twitter">
                        <i class="fab fa-x-twitter"></i>
                        <span>Twitter</span>
                    </a>
                    <a href="https://www.linkedin.com/sharing/share-offsite/?url=" class="share-btn linkedin" target="_blank" rel="noopener noreferrer" data-share="linkedin">
                        <i class="fab fa-linkedin-in"></i>
                        <span>LinkedIn</span>
                    </a>
                    <a href="https://wa.me/?text=Check%20out%20DRNF%20FAQs%20-%20" class="share-btn whatsapp" target="_blank" rel="noopener noreferrer" data-share="whatsapp">
                        <i class="fab fa-whatsapp"></i>
                        <span>WhatsApp</span>
                    </a>
                </div>
            </div>
        </div>
    </section>

  <!-- Back to Top Button -->
  <button class="back-to-top" id="backToTop" aria-label="Back to top">
    <i class="fas fa-arrow-up"></i>
  </button>

</Layout>

<script>
  // Current year in footer
  if (typeof document !== 'undefined') {
    const yearElement = document.getElementById('current-year');
    if (yearElement) {
      yearElement.textContent = new Date().getFullYear();
    }
    
    // FAQ Accordion
    document.querySelectorAll('.faq-question').forEach(question => {
      question.addEventListener('click', () => {
        const item = question.parentElement;
        const isActive = item.classList.contains('active');

        // Close all items
        document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('active'));

        // Open clicked item if it wasn't active
        if (!isActive) {
          item.classList.add('active');
        }
      });
    });
  }
</script>
