---
import Layout from '../layouts/Layout.astro';
import NewsletterSignup from '../components/react/NewsletterSignup.tsx';

const pageTitle = 'Transparency & Accountability | Dr. Rabinder Nath Foundation';
const pageDescription = "Complete transparency on DRNF's operations, finances, impact methodology, and cost-effectiveness. See where every rupee goes and how we measure our impact.";
---

<Layout title={pageTitle} description={pageDescription}>
  
<section class="transparency-hero">
        <div class="container">
            <h1 data-aos="fade-up">Transparency & Accountability</h1>
            <p data-aos="fade-up" data-aos-delay="100">We believe in complete openness about our operations, finances, and impact. Every rupee counts, and you deserve to know exactly how we create change.</p>
            <div class="trust-badge" data-aos="zoom-in" data-aos-delay="200">
                <i class="fas fa-shield-alt" style="font-size: 1.5rem;"></i>
                <span>Committed to Transparency & Evidence-Based Impact</span>
            </div>
        </div>
    </section>

    <!-- Legal & Registration -->
    <section class="section" style="background: white;">
        <div class="container">
            <h2 class="section-title" data-aos="fade-up">Legal Status & Registration</h2>
            <p class="section-subtitle" data-aos="fade-up">Complete organizational information and regulatory compliance</p>

            <div class="info-grid">
                <div class="info-card" data-aos="fade-up">
                    <h3><i class="fas fa-certificate"></i> Organization Details</h3>
                    <div class="info-item">
                        <span class="info-label">Legal Name:</span>
                        <span class="info-value">Dr. Rabinder Nath Foundation</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Founded:</span>
                        <span class="info-value">2020</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Founder:</span>
                        <span class="info-value">Abhishek Nath</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Legal Structure:</span>
                        <span class="info-value">Charitable Initiative</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Parent Organization:</span>
                        <span class="info-value">Ixora Corporate Services Pvt Ltd</span>
                    </div>
                </div>

                <div class="info-card" data-aos="fade-up" data-aos-delay="100">
                    <h3><i class="fas fa-map-marker-alt"></i> Registered Office</h3>
                    <div class="info-item">
                        <span class="info-label">Address:</span>
                        <span class="info-value">Door No: 8, 2-293/82/J/A/101, Journalist Colony, Jubilee Hills, Hyderabad, Telangana 500033, India</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Phone:</span>
                        <span class="info-value">+91 9966906781</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Email:</span>
                        <span class="info-value">info@drnf.org</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Website:</span>
                        <span class="info-value">https://drnf.org</span>
                    </div>
                </div>

                <div class="info-card" data-aos="fade-up" data-aos-delay="200">
                    <h3><i class="fas fa-file-contract"></i> Tax & Compliance</h3>
                    <p style="color: var(--text-secondary); font-style: italic; margin-bottom: 1.5rem;">
                        As a charitable initiative of Ixora Corporate Services, DRNF operates under Ixora's established legal and tax framework. All donations and expenditures are processed through Ixora's compliant systems.
                    </p>
                    <div class="info-item">
                        <span class="info-label">Compliance Status:</span>
                        <span class="info-value" style="color: #27ae60; font-weight: 600;">✓ Active & Compliant</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Audit Status:</span>
                        <span class="info-value">Audited through Ixora Group</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Leadership & Governance -->
    <section class="section" style="background: linear-gradient(to bottom, #f7fafc 0%, white 100%);">
        <div class="container">
            <h2 class="section-title" data-aos="fade-up">Leadership & Governance</h2>
            <p class="section-subtitle" data-aos="fade-up">The team driving DRNF's mission with integrity and purpose</p>

            <div class="info-grid">
                <div class="info-card" data-aos="fade-up">
                    <h3><i class="fas fa-user-tie"></i> Founder & Executive Leadership</h3>
                    <div style="margin-bottom: 1.5rem;">
                        <h4 style="color: var(--primary-color); margin-bottom: 0.5rem;">Abhishek Nath</h4>
                        <p style="color: var(--text-secondary); font-size: 0.95rem; margin-bottom: 1rem;">
                            <strong>Founder</strong><br>
                            Managing Director & CEO of Ixora Corporate Services Pvt Ltd
                        </p>
                        <p style="color: var(--text-secondary); font-size: 0.9rem; line-height: 1.7;">
                            Founded DRNF in 2020 to honor his father's legacy. Under his leadership, DRNF has served 500-600 people daily through free chai counters, created 70+ jobs, and supported frontline workers through COVID-19 and beyond.
                        </p>
                    </div>
                </div>

                <div class="info-card" data-aos="fade-up" data-aos-delay="100">
                    <h3><i class="fas fa-users"></i> Advisory & Support</h3>
                    <p style="color: var(--text-secondary); line-height: 1.7; margin-bottom: 1rem;">
                        DRNF benefits from the expertise and support of Ixora Corporate Services' leadership team, which includes professionals in facilities management, operations, finance, and community engagement.
                    </p>
                    <div class="info-item">
                        <span class="info-label">Operational Support:</span>
                        <span class="info-value">Ixora Corporate Services</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Staff Count:</span>
                        <span class="info-value">40+ full-time associates</span>
                    </div>
                </div>

                <div class="info-card" data-aos="fade-up" data-aos-delay="200">
                    <h3><i class="fas fa-handshake"></i> Strategic Partners</h3>
                    <div class="info-item">
                        <span class="info-label">LooCafe:</span>
                        <span class="info-value">Infrastructure & Location Partner (270+ facilities)</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Kadak Chai:</span>
                        <span class="info-value">Chai Supply Partnership</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Abhi Sai Datta Trust:</span>
                        <span class="info-value">Educational Workshop Partnership</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">GHMC:</span>
                        <span class="info-value">COVID-19 PPE Distribution Partner</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Financial Transparency -->
    <section class="section" style="background: white;">
        <div class="container">
            <h2 class="section-title" data-aos="fade-up">Financial Transparency</h2>
            <p class="section-subtitle" data-aos="fade-up">See exactly how we allocate resources to maximize impact</p>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; margin-top: 3rem; align-items: start;">
                <div data-aos="fade-right">
                    <h3 style="font-size: 1.8rem; color: var(--primary-color); margin-bottom: 2rem;">Fund Allocation (Est. 2024)</h3>
                    <div class="chart-placeholder">
                        <i class="fas fa-chart-pie" style="font-size: 4rem; color: #cbd5e0; margin-bottom: 1rem;"></i>
                        <h4 style="color: var(--text-secondary); margin-bottom: 1rem;">Allocation Breakdown</h4>
                        <div style="text-align: left; width: 100%; max-width: 400px;">
                            <div style="padding: 1rem; background: white; border-radius: 8px; margin-bottom: 0.5rem;">
                                <strong style="color: var(--primary-color);">~85%</strong> Program Services (Chai, Food, Direct Support)
                            </div>
                            <div style="padding: 1rem; background: white; border-radius: 8px; margin-bottom: 0.5rem;">
                                <strong style="color: var(--secondary-color);">~10%</strong> Operations & Employment
                            </div>
                            <div style="padding: 1rem; background: white; border-radius: 8px;">
                                <strong style="color: var(--accent-color);">~5%</strong> Administration & Overhead
                            </div>
                        </div>
                    </div>
                </div>

                <div data-aos="fade-left">
                    <h3 style="font-size: 1.8rem; color: var(--primary-color); margin-bottom: 2rem;">Key Financial Principles</h3>
                    <div class="info-card" style="margin-bottom: 1.5rem;">
                        <h4 style="color: var(--primary-color); margin-bottom: 1rem;"><i class="fas fa-chart-line"></i> Lean Operations</h4>
                        <p style="color: var(--text-secondary); line-height: 1.7;">
                            By partnering with LooCafe and leveraging existing infrastructure, we keep overhead costs minimal—typically under 5% of total spending.
                        </p>
                    </div>

                    <div class="info-card" style="margin-bottom: 1.5rem;">
                        <h4 style="color: var(--primary-color); margin-bottom: 1rem;"><i class="fas fa-users"></i> Job Creation as Impact</h4>
                        <p style="color: var(--text-secondary); line-height: 1.7;">
                            70+ jobs created means employment costs are <strong>program impact</strong>, not overhead. Every worker hired lifts a family out of poverty.
                        </p>
                    </div>

                    <div class="info-card">
                        <h4 style="color: var(--primary-color); margin-bottom: 1rem;"><i class="fas fa-check-double"></i> Ixora Group Support</h4>
                        <p style="color: var(--text-secondary); line-height: 1.7;">
                            Many administrative costs are covered by Ixora Corporate Services, allowing more donated funds to go directly to programs.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Cost-Effectiveness -->
    <section class="section" style="background: linear-gradient(135deg, rgba(102,126,234,0.05) 0%, rgba(118,75,162,0.05) 100%);">
        <div class="container">
            <h2 class="section-title" data-aos="fade-up">Cost-Effectiveness Analysis</h2>
            <p class="section-subtitle" data-aos="fade-up">See exactly what your contribution accomplishes</p>

            <div class="metric-grid">
                <div class="metric-card" data-aos="zoom-in">
                    <div class="metric-value">₹2</div>
                    <div class="metric-label">Cost per Cup of Chai Served</div>
                    <p style="color: var(--text-secondary); font-size: 0.9rem; margin-top: 1rem; line-height: 1.6;">
                        Includes tea, sugar, milk, water, and cup. Bulk purchasing keeps costs low.
                    </p>
                </div>

                <div class="metric-card" data-aos="zoom-in" data-aos-delay="100">
                    <div class="metric-value">₹1,000</div>
                    <div class="metric-label">Serves 500 People</div>
                    <p style="color: var(--text-secondary); font-size: 0.9rem; margin-top: 1rem; line-height: 1.6;">
                        Your ₹1,000 donation provides warm chai to 500 individuals in need.
                    </p>
                </div>

                <div class="metric-card" data-aos="zoom-in" data-aos-delay="200">
                    <div class="metric-value">₹30,000</div>
                    <div class="metric-label">One Month at One Counter</div>
                    <p style="color: var(--text-secondary); font-size: 0.9rem; margin-top: 1rem; line-height: 1.6;">
                        Covers chai supplies + 2 staff salaries for one counter for one month.
                    </p>
                </div>

                <div class="metric-card" data-aos="zoom-in" data-aos-delay="300">
                    <div class="metric-value">₹3,60,000</div>
                    <div class="metric-label">Full Year Operation</div>
                    <p style="color: var(--text-secondary); font-size: 0.9rem; margin-top: 1rem; line-height: 1.6;">
                        Annual cost to run one counter: 180,000+ cups served, 2 jobs sustained.
                    </p>
                </div>
            </div>

            <div style="background: white; padding: 3rem; border-radius: 20px; margin-top: 3rem;" data-aos="fade-up">
                <h3 style="font-size: 2rem; color: var(--primary-color); margin-bottom: 2rem; text-align: center;">Your Impact at Different Levels</h3>
                <div class="info-grid">
                    <div class="info-card">
                        <h4 style="color: var(--primary-color); font-size: 1.3rem; margin-bottom: 1rem;">₹500 Donation</h4>
                        <ul style="list-style: none; padding: 0; margin: 0;">
                            <li style="padding: 0.5rem 0; color: var(--text-secondary);">
                                <i class="fas fa-check-circle" style="color: #27ae60; margin-right: 0.5rem;"></i>
                                250 cups of chai served
                            </li>
                            <li style="padding: 0.5rem 0; color: var(--text-secondary);">
                                <i class="fas fa-check-circle" style="color: #27ae60; margin-right: 0.5rem;"></i>
                                ~125 people directly impacted
                            </li>
                        </ul>
                    </div>

                    <div class="info-card">
                        <h4 style="color: var(--primary-color); font-size: 1.3rem; margin-bottom: 1rem;">₹5,000 Donation</h4>
                        <ul style="list-style: none; padding: 0; margin: 0;">
                            <li style="padding: 0.5rem 0; color: var(--text-secondary);">
                                <i class="fas fa-check-circle" style="color: #27ae60; margin-right: 0.5rem;"></i>
                                2,500 cups of chai served
                            </li>
                            <li style="padding: 0.5rem 0; color: var(--text-secondary);">
                                <i class="fas fa-check-circle" style="color: #27ae60; margin-right: 0.5rem;"></i>
                                ~1,250 people directly impacted
                            </li>
                            <li style="padding: 0.5rem 0; color: var(--text-secondary);">
                                <i class="fas fa-check-circle" style="color: #27ae60; margin-right: 0.5rem;"></i>
                                5 days of full counter operation
                            </li>
                        </ul>
                    </div>

                    <div class="info-card">
                        <h4 style="color: var(--primary-color); font-size: 1.3rem; margin-bottom: 1rem;">₹30,000 Donation</h4>
                        <ul style="list-style: none; padding: 0; margin: 0;">
                            <li style="padding: 0.5rem 0; color: var(--text-secondary);">
                                <i class="fas fa-check-circle" style="color: #27ae60; margin-right: 0.5rem;"></i>
                                Full month of counter operation
                            </li>
                            <li style="padding: 0.5rem 0; color: var(--text-secondary);">
                                <i class="fas fa-check-circle" style="color: #27ae60; margin-right: 0.5rem;"></i>
                                15,000+ cups served
                            </li>
                            <li style="padding: 0.5rem 0; color: var(--text-secondary);">
                                <i class="fas fa-check-circle" style="color: #27ae60; margin-right: 0.5rem;"></i>
                                2 staff salaries for 1 month
                            </li>
                            <li style="padding: 0.5rem 0; color: var(--text-secondary);">
                                <i class="fas fa-check-circle" style="color: #27ae60; margin-right: 0.5rem;"></i>
                                ~7,500 individuals impacted
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Impact Methodology -->
    <section class="section" style="background: white;">
        <div class="container">
            <h2 class="section-title" data-aos="fade-up">How We Measure Impact</h2>
            <p class="section-subtitle" data-aos="fade-up">Evidence-based approach to tracking and reporting our work</p>

            <div class="info-grid" style="margin-top: 3rem;">
                <div class="info-card" data-aos="fade-up">
                    <h3><i class="fas fa-clipboard-check"></i> Data Collection</h3>
                    <ul style="list-style: none; padding: 0; margin: 0;">
                        <li style="padding: 0.75rem 0; border-bottom: 1px solid #eee;">
                            <strong style="color: var(--primary-color);">Daily Counts:</strong>
                            <span style="color: var(--text-secondary);"> Counter staff record cups served and beneficiaries</span>
                        </li>
                        <li style="padding: 0.75rem 0; border-bottom: 1px solid #eee;">
                            <strong style="color: var(--primary-color);">Financial Tracking:</strong>
                            <span style="color: var(--text-secondary);"> All expenses logged through Ixora's accounting system</span>
                        </li>
                        <li style="padding: 0.75rem 0;">
                            <strong style="color: var(--primary-color);">Employment Records:</strong>
                            <span style="color: var(--text-secondary);"> HR data tracks jobs created and sustained</span>
                        </li>
                    </ul>
                </div>

                <div class="info-card" data-aos="fade-up" data-aos-delay="100">
                    <h3><i class="fas fa-calculator"></i> Calculation Methods</h3>
                    <ul style="list-style: none; padding: 0; margin: 0;">
                        <li style="padding: 0.75rem 0; border-bottom: 1px solid #eee;">
                            <strong style="color: var(--primary-color);">People Served:</strong>
                            <span style="color: var(--text-secondary);"> Daily cups ÷ 2 (avg 2 cups/person) = unique individuals</span>
                        </li>
                        <li style="padding: 0.75rem 0; border-bottom: 1px solid #eee;">
                            <strong style="color: var(--primary-color);">Cost/Cup:</strong>
                            <span style="color: var(--text-secondary);"> Total supply cost ÷ total cups served</span>
                        </li>
                        <li style="padding: 0.75rem 0;">
                            <strong style="color: var(--primary-color);">Jobs Created:</strong>
                            <span style="color: var(--text-secondary);"> Direct headcount employed by DRNF programs</span>
                        </li>
                    </ul>
                </div>

                <div class="info-card" data-aos="fade-up" data-aos-delay="200">
                    <h3><i class="fas fa-search"></i> Verification & Auditing</h3>
                    <ul style="list-style: none; padding: 0; margin: 0;">
                        <li style="padding: 0.75rem 0; border-bottom: 1px solid #eee;">
                            <strong style="color: var(--primary-color);">Monthly Reviews:</strong>
                            <span style="color: var(--text-secondary);"> Leadership reviews all program data monthly</span>
                        </li>
                        <li style="padding: 0.75rem 0; border-bottom: 1px solid #eee;">
                            <strong style="color: var(--primary-color);">External Audit:</strong>
                            <span style="color: var(--text-secondary);"> Ixora's annual financial audit includes DRNF</span>
                        </li>
                        <li style="padding: 0.75rem 0;">
                            <strong style="color: var(--primary-color);">Public Reporting:</strong>
                            <span style="color: var(--text-secondary);"> Impact data updated on website quarterly</span>
                        </li>
                    </ul>
                </div>
            </div>

            <div style="background: linear-gradient(135deg, rgba(102,126,234,0.1) 0%, rgba(118,75,162,0.1) 100%); padding: 3rem; border-radius: 20px; margin-top: 3rem; text-align: center;" data-aos="fade-up">
                <h3 style="font-size: 1.8rem; color: var(--primary-color); margin-bottom: 1.5rem;">Commitment to Accuracy</h3>
                <p style="font-size: 1.1rem; color: var(--text-secondary); line-height: 1.8; max-width: 900px; margin: 0 auto;">
                    We report <strong>conservative estimates</strong> whenever exact data is unavailable. For example, "500-600 people daily" reflects the range we can confidently document. We never inflate numbers to look better—transparency builds trust, and trust creates lasting impact.
                </p>
            </div>
        </div>
    </section>

    <!-- Reports & Downloads -->
    <section class="section" style="background: linear-gradient(to bottom, #f7fafc 0%, white 100%);">
        <div class="container">
            <h2 class="section-title" data-aos="fade-up">Reports & Documentation</h2>
            <p class="section-subtitle" data-aos="fade-up">Download our impact reports, financial statements, and program data</p>

            <div class="download-section" data-aos="fade-up">
                <h3 style="font-size: 1.8rem; color: var(--primary-color); margin-bottom: 1rem;">Available Reports (Coming Soon)</h3>
                <p style="color: var(--text-secondary); margin-bottom: 2rem;">
                    We're working on comprehensive annual and quarterly reports. Check back soon for downloadable PDFs including:
                </p>

                <div class="download-grid">
                    <div class="download-item">
                        <div class="download-icon">
                            <i class="fas fa-file-pdf"></i>
                        </div>
                        <div>
                            <h4 style="color: var(--primary-color); margin-bottom: 0.25rem;">Annual Impact Report 2024</h4>
                            <p style="color: var(--text-secondary); font-size: 0.9rem; margin: 0;">Complete impact data, stories, and outcomes</p>
                            <p style="color: #cbd5e0; font-size: 0.85rem; margin-top: 0.25rem; font-style: italic;">Coming Q1 2025</p>
                        </div>
                    </div>

                    <div class="download-item">
                        <div class="download-icon">
                            <i class="fas fa-file-invoice-dollar"></i>
                        </div>
                        <div>
                            <h4 style="color: var(--primary-color); margin-bottom: 0.25rem;">Financial Statements 2024</h4>
                            <p style="color: var(--text-secondary); font-size: 0.9rem; margin: 0;">Audited financials and expense breakdown</p>
                            <p style="color: #cbd5e0; font-size: 0.85rem; margin-top: 0.25rem; font-style: italic;">Coming Q1 2025</p>
                        </div>
                    </div>

                    <div class="download-item">
                        <div class="download-icon">
                            <i class="fas fa-chart-bar"></i>
                        </div>
                        <div>
                            <h4 style="color: var(--primary-color); margin-bottom: 0.25rem;">Quarterly Updates</h4>
                            <p style="color: var(--text-secondary); font-size: 0.9rem; margin: 0;">Regular program progress reports</p>
                            <p style="color: #cbd5e0; font-size: 0.85rem; margin-top: 0.25rem; font-style: italic;">Coming Q1 2025</p>
                        </div>
                    </div>
                </div>
            </div>

            <div style="background: white; padding: 3rem; border-radius: 20px; margin-top: 3rem; text-align: center; box-shadow: 0 4px 20px rgba(0,0,0,0.08);" data-aos="fade-up">
                <h3 style="font-size: 1.8rem; color: var(--primary-color); margin-bottom: 1rem;">Questions About Our Data?</h3>
                <p style="font-size: 1.1rem; color: var(--text-secondary); margin-bottom: 2rem; line-height: 1.7;">
                    We're committed to complete transparency. If you have questions about our financials, impact methodology, or want more detailed data, we're here to help.
                </p>
                <a href="/contact" class="btn btn-primary btn-large">Contact Us</a>
            </div>
        </div>
    </section>

    <!-- Call to Action -->
    <section class="cta-section section">
        <div class="container">
            <div class="cta-content">
                <h2 class="section-title" data-aos="fade-up">Support Evidence-Based Impact</h2>
                <p class="section-subtitle" data-aos="fade-up">Your contribution funds programs backed by data, transparency, and evidence-based methodology</p>
                <div class="cta-buttons" data-aos="fade-up" data-aos-delay="200">
                    <a href="/contact" class="btn btn-primary btn-large">Get Involved</a>
                    <a href="/about" class="btn btn-secondary btn-large">Learn More</a>
                </div>
            </div>
        </div>
    </section>
  
  
  
    <!-- Newsletter Signup -->
    <NewsletterSignup client:load />
</Layout>





<script>
  // Current year in footer
  if (typeof document !== 'undefined') {
    const yearElement = document.getElementById('current-year');
    if (yearElement) {
      yearElement.textContent = new Date().getFullYear();
    }
  }
</script>
