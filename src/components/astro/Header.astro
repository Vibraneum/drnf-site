---
import MobileNav from '../react/MobileNav';

/**
 * Header Component - DRNF Website Navigation
 *
 * Redesigned with Ixora Group-style navigation:
 * - Hover-based mega menus (smooth transitions, no box opening)
 * - Icons for all navigation links
 * - Comprehensive navigation with more backlinks
 * - React-powered mobile menu with full client-side interactivity
 * - Smooth, polished UX
 */

interface Props {
  activePage?: string;
}

const { activePage = '' } = Astro.props;
const currentPath = Astro.url.pathname;

const isActive = (path: string) => {
  if (path === '/' || path === '/index.html') {
    return currentPath === '/' || currentPath === '/index.html' || currentPath === '/index';
  }
  return currentPath.includes(path.replace('.html', ''));
};
