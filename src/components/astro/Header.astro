.mobile-menu-item-enhanced i {
    font-size: 1.125rem;
    width: 24px;
    text-align: center;
}

.mobile-section-enhanced {
    border-bottom: 1px solid #e5e7eb;
}

.mobile-section-header-enhanced {
    display: flex;
    align-items: center;
    gap: 1rem;
    width: 100%;
    padding: 1rem;
    background: none;
    border: none;
    text-align: left;
    font-weight: 600;
    color: #374151;
    cursor: pointer;
    transition: all 0.2s;
    border-radius: 0.5rem;
}

.mobile-section-header-enhanced:hover {
    background: rgba(212, 180, 88, 0.1);
    color: #D4B258;
}

.mobile-section-header-enhanced i:first-child {
    font-size: 1.125rem;
    width: 24px;
    text-align: center;
}

.mobile-chevron-enhanced {
    margin-left: auto;
    transition: transform 0.3s;
    font-size: 0.875rem;
}

.mobile-section-header-enhanced.active .mobile-chevron-enhanced {
    transform: rotate(180deg);
}

.mobile-section-content-enhanced {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
}

.mobile-section-content-enhanced.active {
    max-height: 1000px;
}

.mobile-link-enhanced {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.875rem 1rem 0.875rem 3rem;
    color: #6b7280;
    text-decoration: none;
    font-size: 0.9375rem;
    transition: all 0.2s;
    border-radius: 0.5rem;
}

.mobile-link-enhanced:hover {
    background: rgba(212, 180, 88, 0.1);
    color: #D4B258;
}

.mobile-link-enhanced i {
    font-size: 1rem;
    width: 20px;
    text-align: center;
}

.mobile-cta-enhanced {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 1rem;
    padding: 1rem;
    background: linear-gradient(135deg, #D4B258 0%, #C3A24B 100%);
    color: white;
    text-decoration: none;
    font-weight: 600;
    border-radius: 0.5rem;
    transition: all 0.3s;
}

.mobile-cta-enhanced:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(212, 180, 88, 0.4);
}

.mobile-social-enhanced {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid #e5e7eb;
}

.mobile-social-enhanced a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: #f3f4f6;
    color: #374151;
    border-radius: 50%;
    text-decoration: none;
    transition: all 0.2s;
    font-size: 1.25rem;
}

.mobile-social-enhanced a:hover {
    background: #D4B258;
    color: white;
    transform: translateY(-2px);
}
</style>

<script>
// Enhanced Navigation Script - Hover-based mega menus
if (typeof document !== 'undefined') {
    document.addEventListener('DOMContentLoaded', function() {
        const enhancedNav = document.querySelector('.enhanced-nav');
        const navDropdownWrappers = document.querySelectorAll('.nav-dropdown-wrapper');
        const mobileMenuToggle = document.querySelector('.mobile-menu-toggle');
        const mobileMenuOverlay = document.querySelector('.mobile-menu-overlay-enhanced');
        const mobileMenuClose = document.querySelector('.mobile-menu-close-enhanced');
        const mobileSectionHeaders = document.querySelectorAll('.mobile-section-header-enhanced');

        // Scroll effect
        if (enhancedNav) {
            window.addEventListener('scroll', function() {
                if (window.pageYOffset > 50) {
                    enhancedNav.classList.add('scrolled');
                } else {
                    enhancedNav.classList.remove('scrolled');
                }
            });
        }

        // Mobile menu toggle
        if (mobileMenuToggle && mobileMenuOverlay) {
            mobileMenuToggle.addEventListener('click', function() {
                mobileMenuOverlay.classList.add('active');
                mobileMenuToggle.classList.add('active');
                document.body.style.overflow = 'hidden';
            });
        }

        if (mobileMenuClose && mobileMenuOverlay) {
            mobileMenuClose.addEventListener('click', function() {
                mobileMenuOverlay.classList.remove('active');
                if (mobileMenuToggle) {
                    mobileMenuToggle.classList.remove('active');
                }
                document.body.style.overflow = '';
            });
        }

        // Close mobile menu when clicking outside
        if (mobileMenuOverlay) {
            mobileMenuOverlay.addEventListener('click', function(e) {
                if (e.target === mobileMenuOverlay) {
                    mobileMenuOverlay.classList.remove('active');
                    if (mobileMenuToggle) {
                        mobileMenuToggle.classList.remove('active');
                    }
                    document.body.style.overflow = '';
                }
            });
        }

        // Mobile accordion sections
        mobileSectionHeaders.forEach(header => {
            header.addEventListener('click', function() {
                const toggleId = this.getAttribute('data-toggle');
                const content = document.getElementById(toggleId);
                const isActive = this.classList.contains('active');

                // Close all other sections
                mobileSectionHeaders.forEach(h => {
                    if (h !== this) {
                        h.classList.remove('active');
                        const otherContent = document.getElementById(h.getAttribute('data-toggle'));
                        if (otherContent) {
                            otherContent.classList.remove('active');
                        }
                    }
                });

                // Toggle current section
                if (isActive) {
                    this.classList.remove('active');
                    if (content) {
                        content.classList.remove('active');
                    }
                } else {
                    this.classList.add('active');
                    if (content) {
                        content.classList.add('active');
                    }
                }
            });
        });

        // Close mobile menu on link click
        const mobileLinks = document.querySelectorAll('.mobile-menu-item-enhanced, .mobile-link-enhanced, .mobile-cta-enhanced');
        mobileLinks.forEach(link => {
            link.addEventListener('click', function() {
                if (mobileMenuOverlay) {
                    mobileMenuOverlay.classList.remove('active');
                    if (mobileMenuToggle) {
                        mobileMenuToggle.classList.remove('active');
                    }
                    document.body.style.overflow = '';
                }
            });
        });

        // Close mega menus when clicking outside
        document.addEventListener('click', function(e) {
            if (!e.target.closest('.nav-dropdown-wrapper') && !e.target.closest('.mega-menu-enhanced')) {
                const megaMenus = document.querySelectorAll('.mega-menu-enhanced');
                megaMenus.forEach(menu => {
                    menu.style.opacity = '0';
                    menu.style.visibility = 'hidden';
                    menu.style.transform = 'translateY(-10px)';
                    menu.style.pointerEvents = 'none';
                });
            }
        });
    });
}
</script>
