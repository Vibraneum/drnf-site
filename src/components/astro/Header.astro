---
/**
 * Header Component - DRNF Website Navigation
 *
 * Complete navigation header extracted from current DRNF website (index.html lines 150-420)
 *
 * Features:
 * - Desktop navigation with mega menus (About, Our Programs)
 * - Mobile hamburger menu with expandable accordion sections
 * - Sticky header with glassmorphism effect
 * - Active page highlighting
 * - "Our Story" CTA button (per CLAUDE.md: NOT "Volunteer Today")
 * - Social media links in mobile menu
 *
 * Props:
 * - activePage (optional): Current active page identifier for highlighting
 *
 * Note: This component preserves the exact navigation structure from the current site.
 * Mobile menu interactivity (accordion toggles) handled by existing /js/main.js
 */

interface Props {
  activePage?: string;
}

const { activePage = '' } = Astro.props;
const currentPath = Astro.url.pathname;

// Helper function to check if current page matches
const isActive = (path: string) => {
  if (path === '/' || path === '/index.html') {
    return currentPath === '/' || currentPath === '/index.html' || currentPath === '/index';
  }
  return currentPath.includes(path.replace('.html', ''));
};
---

<!-- Main Enhanced Navigation -->
<nav class="enhanced-nav" id="enhancedNav">
    <div class="nav-container-enhanced">
        <!-- Logo & Brand -->
        <a href="/" class="nav-logo-enhanced">
            <img
                src="https://res.cloudinary.com/dhupieu4x/image/upload/v1762599287/drnf-assets/drnf-assets/DRNF_logo.jpg"
                alt="Dr. Rabinder Nath Foundation Logo"
                class="logo-img"
                width="60"
                height="60"
            />
            <div class="nav-brand-text">
                <h1 class="brand-title">Dr. Rabinder Nath Foundation</h1>
                <p class="brand-tagline">Serving with Compassion</p>
            </div>
        </a>

        <!-- Desktop Navigation Links -->
        <ul class="nav-links-enhanced">
            <li>
                <a
                    href="/"
                    class:list={["nav-link-enhanced", { active: isActive('/') }]}
                >
                    Home
                </a>
            </li>

            <!-- About Dropdown -->
            <li>
                <div
                    class:list={[
                        "nav-link-enhanced",
                        "nav-dropdown-trigger",
                        { active: activePage === "about" }
                    ]}
                    data-menu="about-mega-menu"
                >
                    <span>About</span>
                    <svg class="chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24" width="16" height="16">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                    </svg>
                </div>
            </li>

            <li>
                <a
                    href="/book"
                    class:list={["nav-link-enhanced", { active: isActive('/book') }]}
                >
                    Heritage Book
                </a>
            </li>

            <!-- Programs Dropdown -->
            <li>
                <div
                    class:list={[
                        "nav-link-enhanced",
                        "nav-dropdown-trigger",
                        { active: activePage === "programs" }
                    ]}
                    data-menu="programs-mega-menu"
                >
                    <span>Our Programs</span>
                    <svg class="chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24" width="16" height="16">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                    </svg>
                </div>
            </li>

            <li>
                <a
                    href="/contact"
                    class:list={["nav-link-enhanced", { active: isActive('/contact') }]}
                >
                    Contact
                </a>
            </li>

            <li>
                <a
                    href="/faq"
                    class:list={["nav-link-enhanced", { active: isActive('/faq') }]}
                >
                    FAQ
                </a>
            </li>
        </ul>

        <!-- Navigation Actions -->
        <div class="nav-actions-enhanced">
            <!-- IMPORTANT: "Our Story" CTA per CLAUDE.md (NOT "Volunteer Today") -->
            <a href="/about" class="nav-cta-enhanced">Our Story</a>
            <button class="mobile-menu-toggle" aria-label="Toggle mobile menu">
                <span></span>
                <span></span>
                <span></span>
            </button>
        </div>
    </div>

    <!-- About Mega Menu -->
    <div class="mega-menu" id="about-mega-menu">
